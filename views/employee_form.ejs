<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تحديث بيانات الموظفين | منصة أبو حمزة</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --navy: #0b1d2a; --gold: #ffcc00; --bg: #f4f7f6; --success: #27ae60; --gray: #666; --red: #e74c3c; }
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); display: flex; justify-content: center; padding: 20px; margin: 0; }
        
        .form-card { 
            background: white; width: 100%; max-width: 600px; padding: 35px; 
            border-radius: 25px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); 
            border-top: 10px solid var(--navy); position: relative; 
        }

        .progress-container { width: 100%; background: #eee; height: 8px; border-radius: 10px; margin-bottom: 25px; overflow: hidden; }
        .progress-bar { width: 0%; height: 100%; background: var(--gold); transition: 0.5s ease; }
        
        .motivation { color: var(--success); font-weight: bold; margin-bottom: 20px; text-align: center; min-height: 24px; font-size: 18px; }
        
        .step { display: none; }
        .step.active { display: block; animation: fadeIn 0.5s forwards; }
        
        label { display: block; margin-bottom: 8px; font-size: 1rem; color: var(--navy); font-weight: 700; margin-top: 15px; }
        input, select { width: 100%; padding: 14px; border: 2px solid #eee; border-radius: 12px; font-family: 'Tajawal'; font-size: 16px; margin-bottom: 5px; box-sizing: border-box; transition: 0.3s; }
        input:focus, select:focus { border-color: var(--gold); outline: none; background: #fffcf0; }
        
        .btn-group { display: flex; gap: 10px; margin-top: 30px; }
        button { flex: 1; padding: 15px; border-radius: 12px; border: none; font-weight: bold; cursor: pointer; font-family: 'Tajawal'; font-size: 16px; transition: 0.3s; }
        .btn-next { background: var(--navy); color: var(--gold); }
        .btn-next:hover { background: #162e42; }
        .btn-prev { background: #eee; color: #333; }
        
        .hidden-fields { display: none; background: #f9f9f9; padding: 15px; border-radius: 10px; border: 1px dashed #ddd; margin-top: 10px; }
        .phone-hint { font-size: 0.8rem; color: #888; display: block; margin-bottom: 10px; }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        #success-container { display: none; text-align: center; padding: 20px; }
        .success-icon { font-size: 60px; color: var(--success); margin-bottom: 15px; }

        /* ستايل مخصص للتنبيهات */
        .error-msg { color: var(--red); font-size: 0.85rem; margin-top: -5px; display: none; }
    </style>
</head>
<body>

<div class="form-card">
    <div id="form-content">
        <div class="progress-container"><div id="pBar" class="progress-bar"></div></div>
        <div id="motivationMsg" class="motivation">مرحباً بك! لنبدأ بتحديث بياناتك..</div>

        <form id="smartForm">
            <input type="hidden" name="scopeId" value="<%= typeof scope !== 'undefined' ? scope.uniqueId : '' %>">

            <div class="step active" data-step="1">
                <label>الاسم الكامل (كما في الهوية/الإقامة)</label>
                <input type="text" name="fullName" placeholder="الاسم الرباعي" required>
                
                <label>النوع (الجنس)</label>
                <select name="gender" required>
                    <option value="">اختر الجنس...</option>
                    <option value="ذكر">ذكر</option>
                    <option value="أنثى">أنثى</option>
                </select>

                <label>رقم الجوال (واتساب)</label>
                <input type="tel" name="phoneNumber" placeholder="05xxxxxxxx" pattern="05[0-9]{8}" required>
                <span class="phone-hint">يجب أن يبدأ بـ 05 ويتكون من 10 أرقام</span>

                <div class="btn-group">
                    <button type="button" class="btn-next" onclick="nextStep(1, 'ممتاز! الآن حدد نوع الهوية')">التالي ⮕</button>
                </div>
            </div>

            <div class="step" data-step="2">
                <label>نوع الهوية</label>
                <select name="idType" id="idType" onchange="handleIdTypeChange()" required>
                    <option value="">اختر نوع الهوية...</option>
                    <option value="saudi">مواطن (هوية وطنية)</option>
                    <option value="expat">مقيم (إقامة)</option>
                </select>

                <div id="nationalityBox" class="hidden-fields">
                    <label>الجنسية</label>
                    <select name="nationality" id="nationality">
                        <option value="السعودية" id="saudiOpt">المملكة العربية السعودية</option>
                        <option value="مصر">مصر</option>
                        <option value="باكستان">باكستان</option>
                        <option value="الهند">الهند</option>
                        <option value="اليمن">اليمن</option>
                        <option value="السودان">السودان</option>
                        <option value="بنجلاديش">بنجلاديش</option>
                        <option value="أخرى">أخرى</option>
                    </select>
                </div>

                <label id="idLabel">رقم الهوية/الإقامة</label>
                <input type="text" name="idNumber" id="idNumber" placeholder="أدخل الرقم هنا" required pattern="[1-2][0-9]{9}">
                <span id="idError" class="error-msg">رقم الهوية يجب أن يبدأ بـ 1 للسعوديين و 2 للمقيمين</span>

                <label>تاريخ انتهاء الهوية/الإقامة</label>
                <input type="date" name="idExpiry" required>

                <div class="btn-group">
                    <button type="button" class="btn-prev" onclick="prevStep(2)">السابق</button>
                    <button type="button" class="btn-next" onclick="validateIdAndNext(2, 'أحسنت! لنكمل بقية البيانات')">التالي ⮕</button>
                </div>
            </div>

            <div class="step" data-step="3">
                <div id="passportSection">
                    <label>رقم الجواز</label>
                    <input type="text" name="passportNumber" placeholder="رقم الجواز">
                    <label>تاريخ انتهاء الجواز</label>
                    <input type="date" name="passportExpiry">
                </div>

                <label>هل لديك تأمين صحي؟</label>
                <select name="hasHealthInsurance" onchange="toggleBox(this, 'insuranceBox')">
                    <option value="false">لا يوجد</option>
                    <option value="true">نعم، يوجد</option>
                </select>
                <div id="insuranceBox" class="hidden-fields">
                    <label>تاريخ انتهاء التأمين</label>
                    <input type="date" name="insuranceExpiry">
                </div>

                <div class="btn-group">
                    <button type="button" class="btn-prev" onclick="prevStep(3)">السابق</button>
                    <button type="button" class="btn-next" onclick="nextStep(3, 'شارفت على الانتهاء!')">التالي ⮕</button>
                </div>
            </div>

            <div class="step" data-step="4">
                <label>اسم المنشأة الكفيلة (الحالية)</label>
                <input type="text" name="sponsorName" placeholder="كما في الإقامة" required>

                <label>الفرع / مدينة العمل</label>
                <input type="text" name="branch" placeholder="مثال: فرع الرياض - الملز">

                <label>عنوان السكن بالتفصيل</label>
                <input type="text" name="address" placeholder="الحي، الشارع، رقم المبنى">

                <div class="btn-group">
                    <button type="button" class="btn-prev" onclick="prevStep(4)">السابق</button>
                    <button type="submit" class="btn-next" style="background:var(--success); color:white;">إرسال البيانات واعتمادها 🚀</button>
                </div>
            </div>
        </form>
    </div>

    <div id="success-container">
        <div class="success-icon">✓</div>
        <h2>تم الحفظ بنجاح يا بطل!</h2>
        <p>شكراً لتحديث بياناتك، سيتم مراجعتها من قبل الإدارة.</p>
        <button class="btn-next" onclick="window.location.reload()">تحديث بيانات موظف آخر</button>
    </div>
</div>

<script>
    let current = 1;
    const total = 4;

    function handleIdTypeChange() {
        const type = document.getElementById('idType').value;
        const natBox = document.getElementById('nationalityBox');
        const natSelect = document.getElementById('nationality');
        const idLabel = document.getElementById('idLabel');
        const idInput = document.getElementById('idNumber');
        const passportSection = document.getElementById('passportSection');

        if (type === 'saudi') {
            natBox.style.display = 'none';
            natSelect.value = 'السعودية';
            idLabel.innerText = 'رقم الهوية الوطنية';
            idInput.placeholder = 'يبدأ برقم 1...';
            passportSection.style.display = 'none'; // المواطن غالباً لا يرفع الجواز هنا
        } else if (type === 'expat') {
            natBox.style.display = 'block';
            natSelect.value = ''; // يترك فارغاً ليختار المقيم جنسيته
            idLabel.innerText = 'رقم الإقامة';
            idInput.placeholder = 'يبدأ برقم 2...';
            passportSection.style.display = 'block';
        }
    }

    function validateIdAndNext(step, msg) {
        const type = document.getElementById('idType').value;
        const idVal = document.getElementById('idNumber').value;
        const errorEl = document.getElementById('idError');

        if (type === 'saudi' && !idVal.startsWith('1')) {
            errorEl.style.display = 'block';
            return;
        } else if (type === 'expat' && !idVal.startsWith('2')) {
            errorEl.style.display = 'block';
            return;
        } else if (idVal.length !== 10) {
            errorEl.innerText = "يجب أن يتكون الرقم من 10 خانات";
            errorEl.style.display = 'block';
            return;
        }

        errorEl.style.display = 'none';
        nextStep(step, msg);
    }

    function nextStep(step, msg) {
        const currentStepEl = document.querySelector(`[data-step="${step}"]`);
        const inputs = currentStepEl.querySelectorAll('input[required], select[required]');
        
        for (let input of inputs) {
            if (!input.value) {
                input.style.borderColor = 'red';
                input.reportValidity();
                return;
            }
            input.style.borderColor = '#eee';
        }

        currentStepEl.classList.remove('active');
        document.querySelector(`[data-step="${step+1}"]`).classList.add('active');
        document.getElementById('motivationMsg').innerText = msg;
        current++;
        updateProgress();
    }

    function prevStep(step) {
        document.querySelector(`[data-step="${step}"]`).classList.remove('active');
        document.querySelector(`[data-step="${step-1}"]`).classList.add('active');
        current--;
        updateProgress();
    }

    function updateProgress() {
        const progress = ((current - 1) / (total - 1)) * 100;
        document.getElementById('pBar').style.width = progress + '%';
    }

    function toggleBox(select, boxId) {
        document.getElementById(boxId).style.display = select.value === 'true' ? 'block' : 'none';
    }

    document.getElementById('smartForm').onsubmit = async (e) => {
        e.preventDefault();
        const submitBtn = e.target.querySelector('button[type="submit"]');
        submitBtn.innerText = "جاري الحفظ...";
        submitBtn.disabled = true;

        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);
        
        try {
            const res = await fetch('/employee/api/register', { 
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            });
            
            if(res.ok) {
                document.getElementById('form-content').style.display = 'none';
                document.getElementById('success-container').style.display = 'block';
            } else {
                alert('عذراً، حدث خطأ. تأكد من صحة البيانات.');
                submitBtn.innerText = "إرسال البيانات واعتمادها 🚀";
                submitBtn.disabled = false;
            }
        } catch (error) {
            alert('فشل الاتصال بالسيرفر.');
            submitBtn.disabled = false;
        }
    };
</script>
</body>
</html>