<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لوحة التحكم | أبو حمزة</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --navy: #0d2d4d; --gold: #ffcc00; --teal: #1abc9c; --bg: #f4f7f6; --red: #e74c3c; }
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; display: flex; }
        .sidebar { width: 250px; background: var(--navy); color: white; height: 100vh; position: fixed; padding: 20px; }
        .main-content { margin-right: 250px; flex: 1; padding: 30px; }
        .sidebar-nav { list-style: none; padding: 0; }
        .sidebar-nav a { color: white; text-decoration: none; display: block; padding: 12px; border-radius: 8px; cursor: pointer; margin-bottom: 10px; }
        .sidebar-nav a:hover, .sidebar-nav a.active { background: var(--teal); }
        .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th, td { padding: 12px; text-align: right; border-bottom: 1px solid #eee; }
    </style>
</head>
<body>

    <script>
        // 🛡️ حارس الأمان المطور لمنع الثقل
        (function checkAuth() {
            if (localStorage.getItem('role') !== 'super-admin') {
                const pass = prompt("أدخل كلمة المرور يا أبو حمزة:");
                if (pass === 'hDB3xqff@') {
                    localStorage.setItem('role', 'super-admin');
                } else {
                    window.location.replace('/');
                }
            }
        })();

        function logout() {
            localStorage.clear();
            window.location.replace('/');
        }
    </script>

    <div class="sidebar">
        <h2 style="color: var(--gold);">الكوارتز السحابي</h2>
        <ul class="sidebar-nav">
            <li><a onclick="showSection('add-scope', this)" class="active">✨ إضافة نطاق</a></li>
            <li><a onclick="showSection('view-managers', this)">👥 المدراء</a></li>
            <li><a onclick="logout()" style="color: var(--red);">تسجيل الخروج 🚪</a></li>
        </ul>
    </div>

    <div class="main-content">
        <h1>لوحة التحكم | أبو حمزة</h1>
        
        <div id="add-scope" class="page-section">
            <div class="card">
                <h3>🆕 إنشاء نطاق شركة جديد</h3>
                </div>
        </div>

        <div id="view-managers" class="page-section" style="display:none;">
            <div class="card">
                <h3>👥 قائمة المدراء</h3>
                <table>
                    <thead>
                        <tr><th>الاسم</th><th>البريد</th><th>النطاق</th></tr>
                    </thead>
                    <tbody id="mgr-table"></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        function showSection(id, el) {
            document.querySelectorAll('.page-section').forEach(s => s.style.display = 'none');
            document.getElementById(id).style.display = 'block';
            document.querySelectorAll('.sidebar-nav a').forEach(a => a.classList.remove('active'));
            el.classList.add('active');
            if(id === 'view-managers') loadManagers();
        }

        async function loadManagers() {
            // ✅ تم إضافة /admin/ ليتطابق مع تعريف السيرفر
            const res = await fetch('/admin/get-all-managers');
            const data = await res.json();
            const tbody = document.getElementById('mgr-table');
            tbody.innerHTML = data.map(m => `<tr><td>${m.name}</td><td>${m.email}</td><td>${m.scopeId}</td></tr>`).join('');
        }
    </script>
</body>
</html>