<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | منصة أبو حمزة الذكية</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        :root {
            --navy: #0b1d2a; --gold: #ffcc00; --white: #ffffff;
            --danger: #ff4757; --warning: #ffa502; --success: #2ed573;
            --gray: #7f8c8d; --bg: #f0f2f5; --shadow: 0 8px 30px rgba(0,0,0,0.12);
            /* تدرجات الألوان المطلوبة */
            --glass-blue: rgba(235, 245, 255, 0.85);
            --gold-green-grad: linear-gradient(135deg, rgba(255, 204, 0, 0.1) 0%, rgba(46, 213, 115, 0.1) 100%);
        }
        
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; color: #2d3436; }
        
        header {
            background: var(--navy); color: var(--gold); padding: 15px 30px;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4); position: sticky; top: 0; z-index: 1000;
        }
        
        .container { max-width: 1500px; margin: 0 auto; padding: 25px; }

        /* شريط الإحصائيات */
        .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card {
            background: white; padding: 25px; border-radius: 18px; text-align: center;
            box-shadow: var(--shadow); border-bottom: 5px solid var(--navy); position: relative;
        }
        .stat-val { font-size: 2.5rem; font-weight: 800; color: var(--navy); display: block; }
        .stat-label { font-weight: 500; color: var(--gray); font-size: 1.1rem; }

        /* الأدوات */
        .toolbar {
            background: white; padding: 20px; border-radius: 15px; margin-bottom: 25px;
            display: flex; gap: 15px; align-items: center; box-shadow: var(--shadow); flex-wrap: wrap;
        }
        .search-box { flex: 2; position: relative; min-width: 300px; }
        .search-box input {
            width: 100%; padding: 14px 45px 14px 15px; border: 2px solid #eef0f2;
            border-radius: 12px; font-size: 1rem; outline: none; font-family: 'Tajawal'; transition: 0.3s;
        }
        .search-box i { position: absolute; right: 18px; top: 50%; transform: translateY(-50%); color: var(--navy); }

        .main-btn { padding: 12px 22px; border-radius: 12px; border: none; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 10px; font-family: 'Tajawal'; transition: 0.3s; }

        /* الجدول */
        .table-wrapper { background: white; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
        table { width: 100%; border-collapse: collapse; }
        thead th { background: var(--navy); color: var(--gold); padding: 20px; font-size: 1rem; }
        tbody tr:hover { background: #f9fbff; }
        td { padding: 18px; text-align: center; border-bottom: 1px solid #edf2f7; }

        /* مودال التفاصيل (المصفوفة 3*3) */
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,10,20,0.85); z-index:3000; backdrop-filter: blur(10px); }
        .modal-content { 
            background: #fff; width:95%; max-width:1200px; margin:3vh auto; padding:30px; 
            border-radius:30px; position: relative; max-height: 90vh; overflow-y: auto;
            border-top: 10px solid var(--gold);
        }
        
        .matrix-grid { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 20px; 
            margin-top: 25px; 
        }
        
        .info-card { 
            border-radius: 20px; 
            padding: 20px; 
            border: 1px solid rgba(0,0,0,0.05);
            transition: 0.3s;
        }
        
        /* الألوان المطلوبة للبطاقات */
        .card-blue { background: var(--glass-blue); border-right: 6px solid #3498db; }
        .card-gold-green { background: var(--gold-green-grad); border-right: 6px solid var(--success); }
        
        .card-title { 
            display: flex; align-items: center; gap: 10px; 
            color: var(--navy); font-weight: 800; margin-bottom: 15px;
            font-size: 1.1rem; border-bottom: 1px solid rgba(0,0,0,0.08); padding-bottom: 10px;
        }
        
        .data-row { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 0.95rem; }
        .data-label { color: #576574; font-weight: 500; }
        .data-val { font-weight: 700; color: var(--navy); }

        #toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: var(--navy); color: var(--gold); padding: 15px 40px; border-radius: 50px; display: none; z-index: 5000; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }

        @media (max-width: 1000px) { .matrix-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 700px) { .matrix-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

<header>
    <div style="display:flex; align-items:center; gap:15px;">
        <i class="fas fa-microchip fa-2x"></i>
        <h2 style="margin:0">منصة أبو حمزة | <span id="mgrName" style="color:white">لوحة الإدارة</span></h2>
    </div>
    <div style="display:flex; gap:12px;">
        <button class="main-btn" style="background:var(--gold); color:var(--navy)" onclick="copyLink()">
            <i class="fas fa-link"></i> رابط التسجيل
        </button>
        <button class="main-btn" style="background:var(--danger); color:white" onclick="logout()">
            <i class="fas fa-sign-out-alt"></i> خروج
        </button>
    </div>
</header>

<div class="container">
    <div class="stats-bar">
        <div class="stat-card">
            <span class="stat-val" id="totalCount">0</span>
            <span class="stat-label">إجمالي الكادر</span>
        </div>
        <div class="stat-card" style="border-color:var(--danger)">
            <span class="stat-val" id="expiredCount" style="color:var(--danger)">0</span>
            <span class="stat-label">هويات منتهية</span>
        </div>
        <div class="stat-card" style="border-color:var(--warning)">
            <span class="stat-val" id="carCount" style="color:var(--warning)">0</span>
            <span class="stat-label">سيارات العهدة</span>
        </div>
        <div class="stat-card" style="border-color:var(--success)">
            <span class="stat-val" id="insurCount" style="color:var(--success)">0</span>
            <span class="stat-label">التغطية الصحية</span>
        </div>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="ابحث بالاسم، الهوية، الجوال أو الفرع..." onkeyup="filterData()">
        </div>
        <button class="main-btn" style="background:#1d7a46; color:white;" onclick="exportFullExcel()">
            <i class="fas fa-file-excel"></i> تصدير المصفوفة الشاملة (Excel)
        </button>
    </div>

    <div class="table-wrapper">
        <table id="empTable">
            <thead>
                <tr>
                    <th>اسم الموظف</th>
                    <th>رقم الهوية</th>
                    <th>الجنسية</th>
                    <th>رقم الجوال</th>
                    <th>تاريخ الانتهاء</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody id="empTableBody">
                <tr><td colspan="6">جاري تحميل البيانات...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div id="viewModal" class="modal" onclick="if(event.target==this) closeModal()">
    <div class="modal-content">
        <div style="display:flex; justify-content:space-between; align-items:center; border-bottom: 3px solid var(--navy); padding-bottom: 15px;">
            <h2 style="margin:0; color:var(--navy);"><i class="fas fa-database"></i> السجل الرقمي المتكامل للموظف</h2>
            <button onclick="closeModal()" style="border:none; background:none; cursor:pointer; font-size:2.5rem; color:var(--danger)">&times;</button>
        </div>
        
        <div id="modalDetails" class="matrix-grid">
            </div>

        <div style="margin-top:30px; text-align: center;">
            <button class="main-btn" style="background:var(--navy); color:white; min-width:200px; justify-content:center" onclick="closeModal()">إغلاق السجل</button>
        </div>
    </div>
</div>

<div id="toast"></div>

<script>
    let allEmployees = [];
    const currentScopeId = new URLSearchParams(window.location.search).get('scope') || localStorage.getItem('scopeId');

    async function loadData() {
        if (!currentScopeId) return;
        try {
            const res = await fetch(`/manager/api/get-employees/${currentScopeId}`);
            if (res.ok) {
                allEmployees = await res.json();
                renderTable(allEmployees);
                updateStats();
            }
        } catch (e) { showToast("فشل في الاتصال بالقاعدة", true); }
    }

    function renderTable(data) {
        const body = document.getElementById('empTableBody');
        if(data.length === 0) { body.innerHTML = '<tr><td colspan="6">لا توجد بيانات متاحة</td></tr>'; return; }
        
        body.innerHTML = data.map(emp => `
            <tr>
                <td><strong>${emp.fullName}</strong></td>
                <td><code style="background:#eee; padding:3px 8px; border-radius:5px">${emp.idNumber}</code></td>
                <td>${emp.nationality || 'غير محدد'}</td>
                <td>${emp.phoneNumber}</td>
                <td style="color:${isExpired(emp.idExpiry) ? 'red' : 'green'}">${emp.idExpiry || '---'}</td>
                <td>
                    <button class="main-btn" style="background:var(--navy); color:white; padding:8px 15px; font-size:0.85rem" onclick="viewDetails('${emp._id}')">
                        <i class="fas fa-eye"></i> الملف الكامل
                    </button>
                </td>
            </tr>
        `).join('');
    }

    function viewDetails(id) {
        const emp = allEmployees.find(e => e._id === id);
        if(!emp) return;

        // مصفوفة البيانات الـ 9 (3x3)
        const sections = [
            { t: "البيانات الشخصية", i: "user-tie", c: "card-blue", d: { "الاسم": emp.fullName, "الجنسية": emp.nationality, "الحالة": emp.familyStatus } },
            { t: "الهوية والإقامة", i: "id-card", c: "card-gold-green", d: { "رقم الهوية": emp.idNumber, "تاريخ الانتهاء": emp.idExpiry, "مكان الإصدار": emp.idIssuePlace || '---' } },
            { t: "التواصل والعنوان", i: "map-marker-alt", c: "card-blue", d: { "الجوال": emp.phoneNumber, "البريد": emp.email || '---', "المدينة": emp.city || '---' } },
            { t: "وثائق السفر", i: "passport", c: "card-gold-green", d: { "رقم الجواز": emp.passportNumber, "انتهاء الجواز": emp.passportExpiry, "بلد الإصدار": emp.passportIssueCountry || '---' } },
            { t: "بيانات المركبة", i: "car", c: "card-blue", d: { "رقم اللوحة": emp.carPlate || 'بدون', "نوع السيارة": emp.carType || '---', "الموديل": emp.carYear || '---' } },
            { t: "التأمين الصحي", i: "heart-pulse", c: "card-gold-green", d: { "تأمين طبي": emp.hasHealthInsurance ? 'مفعل' : 'ملغى', "الشركة": emp.insuranceCompany || '---', "رقم البوليصة": emp.insuranceNo || '---' } },
            { t: "الرخص والقيادة", i: "driver-card", c: "card-blue", d: { "رخصة قيادة": emp.hasDrivingLicense ? 'نعم' : 'لا', "تفويض مركبة": emp.hasCarAuthorization ? 'ساري' : 'لا يوجد', "فئة الرخصة": emp.licenseClass || '---' } },
            { t: "معلومات الوظيفة", i: "briefcase", c: "card-gold-green", d: { "الفرع": emp.branch || '---', "المسمى": emp.jobTitle || '---', "تاريخ المباشرة": emp.joinDate || '---' } },
            { t: "بيانات إضافية", i: "plus-circle", c: "card-blue", d: { "العائلة بالمملكة": emp.hasFamilyInKSA ? 'نعم' : 'لا', "رقم الطوارئ": emp.emergencyContact || '---', "ملاحظات": emp.notes || 'لا يوجد' } }
        ];

        document.getElementById('modalDetails').innerHTML = sections.map(s => `
            <div class="info-card ${s.c}">
                <div class="card-title"><i class="fas fa-${s.i}"></i> ${s.t}</div>
                ${Object.entries(s.d).map(([label, val]) => `
                    <div class="data-row"><span class="data-label">${label}:</span><span class="data-val">${val || '---'}</span></div>
                `).join('')}
            </div>
        `).join('');

        document.getElementById('viewModal').style.display = 'block';
    }

    // تصدير كل البيانات بدون استثناء
    function exportFullExcel() {
        if(allEmployees.length === 0) return;
        
        const fullMatrix = allEmployees.map(e => ({
            "الاسم الكامل": e.fullName,
            "رقم الهوية/الإقامة": e.idNumber,
            "تاريخ انتهاء الهوية": e.idExpiry,
            "الجنسية": e.nationality,
            "رقم الجوال": e.phoneNumber,
            "البريد الإلكتروني": e.email,
            "المدينة": e.city,
            "الفرع": e.branch,
            "المسمى الوظيفي": e.jobTitle,
            "رقم الجواز": e.passportNumber,
            "تاريخ انتهاء الجواز": e.passportExpiry,
            "لوحة السيارة": e.carPlate,
            "نوع السيارة": e.carType,
            "تأمين طبي": e.hasHealthInsurance ? "مؤمن" : "غير مؤمن",
            "رخصة قيادة": e.hasDrivingLicense ? "متوفرة" : "غير متوفرة",
            "تفويض سيارة": e.hasCarAuthorization ? "يوجد" : "لا يوجد",
            "الوضع العائلي": e.familyStatus,
            "وجود العائلة بالمملكة": e.hasFamilyInKSA ? "نعم" : "لا",
            "رقم الطوارئ": e.emergencyContact,
            "تاريخ الانضمام": e.joinDate
        }));

        const ws = XLSX.utils.json_to_sheet(fullMatrix);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "قاعدة البيانات الشاملة");
        XLSX.writeFile(wb, `سجل_منصة_أبو_حمزة_${new Date().toISOString().split('T')[0]}.xlsx`);
    }

    function isExpired(date) {
        if(!date) return false;
        return new Date(date) < new Date();
    }

    function updateStats() {
        document.getElementById('totalCount').innerText = allEmployees.length;
        document.getElementById('expiredCount').innerText = allEmployees.filter(e => isExpired(e.idExpiry)).length;
        document.getElementById('insurCount').innerText = allEmployees.filter(e => e.hasHealthInsurance).length;
        document.getElementById('carCount').innerText = allEmployees.filter(e => e.carPlate).length;
    }

    function filterData() {
        const term = document.getElementById('searchInput').value.toLowerCase();
        const filtered = allEmployees.filter(e => 
            e.fullName.toLowerCase().includes(term) || 
            e.idNumber.includes(term) || 
            (e.branch && e.branch.toLowerCase().includes(term))
        );
        renderTable(filtered);
    }

    function showToast(msg, err = false) {
        const t = document.getElementById('toast');
        t.innerText = msg; t.style.background = err ? "red" : "var(--navy)";
        t.style.display = 'block'; setTimeout(() => t.style.display = 'none', 3000);
    }

    function closeModal() { document.getElementById('viewModal').style.display = 'none'; }
    function copyLink() {
        const link = `${window.location.origin}/employee/register?scope=${currentScopeId}`;
        navigator.clipboard.writeText(link);
        showToast("تم نسخ الرابط.. أرسله للموظفين");
    }
    function logout() { localStorage.clear(); window.location.href = '/manager/login'; }

    window.onload = loadData;
</script>
</body>
</html>