<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | Golden Cloud</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --navy: #0b1d2a; --gold: #ffcc00; --white: #ffffff;
            --danger: #ff4757; --warning: #ffa502; --success: #2ed573;
            --gray: #7f8c8d; --bg: #f8f9fa; --shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; color: #2d3436; overflow-x: hidden; }
        
        header {
            background: var(--navy); color: var(--gold); padding: 15px 25px;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3); position: sticky; top: 0; z-index: 1000;
        }
        
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }

        .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 15px; margin-bottom: 25px; }
        .stat-card {
            background: white; padding: 20px; border-radius: 15px; text-align: center;
            box-shadow: var(--shadow); transition: 0.3s; border-top: 5px solid var(--navy);
        }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.15); }
        .stat-val { font-size: 2.2rem; font-weight: 700; display: block; color: var(--navy); margin-bottom: 5px; }
        .stat-label { font-size: 1rem; color: #636e72; font-weight: 500; }

        .toolbar {
            background: white; padding: 20px; border-radius: 15px; margin-bottom: 20px;
            display: flex; gap: 15px; align-items: center; box-shadow: var(--shadow); flex-wrap: wrap;
        }
        .search-box { flex: 1; position: relative; min-width: 250px; }
        .search-box input {
            width: 100%; padding: 12px 45px 12px 15px; border: 2px solid #eee;
            border-radius: 10px; font-size: 1rem; outline: none; font-family: 'Tajawal'; transition: 0.3s;
        }
        .search-box input:focus { border-color: var(--navy); }
        .search-box i { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: #b2bec3; }

        .table-wrapper { background: white; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
        .scroll-area { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 1100px; }
        thead th { background: var(--navy); color: var(--gold); padding: 18px; font-size: 0.95rem; font-weight: 700; position: sticky; top: 0; }
        tbody tr { transition: 0.2s; border-bottom: 1px solid #f1f2f6; animation: fadeIn 0.4s ease-in-out; }
        tbody tr:hover { background-color: #fcfcfc; }
        td { padding: 15px; text-align: center; vertical-align: middle; font-size: 0.9rem; }

        .expired { color: var(--danger); font-weight: bold; background: #fff5f5; padding: 2px 5px; border-radius: 4px; }
        .near-expiry { color: var(--warning); font-weight: bold; background: #fffbe6; padding: 2px 5px; border-radius: 4px; }
        .valid { color: var(--success); }

        .badge-nat { padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: bold; background: #f1f2f6; color: var(--navy); border: 1px solid #ddd; display: inline-block; margin-bottom: 4px;}
        .gender-tag { padding: 4px 8px; border-radius: 6px; font-size: 0.8rem; font-weight: bold; }
        .male { background: #e3f2fd; color: #1976d2; }
        .female { background: #fce4ec; color: #c2185b; }
        
        .car-info-box { font-size: 0.75rem; color: #856404; background: #fff9db; padding: 6px; border-radius: 8px; margin-top: 5px; border: 1px solid #ffeeba; display: flex; align-items: center; justify-content: center; gap: 5px; }

        .btn-circle { width: 35px; height: 35px; border-radius: 8px; border: none; cursor: pointer; color: white; transition: 0.3s; display: flex; align-items: center; justify-content: center; }
        .main-btn { padding: 10px 20px; border-radius: 12px; border: none; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; font-family: 'Tajawal'; transition: 0.3s; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .main-btn:active { transform: scale(0.95); }

        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:3000; backdrop-filter: blur(5px); }
        .modal-content { background:white; width:95%; max-width:550px; margin:50px auto; padding:30px; border-radius:25px; position: relative; animation: slideDown 0.3s ease-out; box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideDown { from { transform: translateY(-50px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

        #toast { position: fixed; bottom: 20px; right: 20px; background: var(--navy); color: var(--gold); padding: 15px 25px; border-radius: 10px; display: none; z-index: 4000; box-shadow: 0 5px 15px rgba(0,0,0,0.3); animation: slideDown 0.3s; }
    </style>
</head>
<body>

<header>
    <div style="display:flex; align-items:center; gap:15px;">
        <i class="fas fa-user-shield fa-2x"></i>
        <h2 style="margin:0">إدارة نطاق: <span id="mgrName" style="color:white">جاري التحميل...</span></h2>
    </div>
    <div style="display:flex; gap:10px;">
        <button class="main-btn" style="background:#6c5ce7; color:white;" onclick="goToLicenses()">
            <i class="fas fa-file-contract"></i> السجلات والرخص
        </button>
        <button class="main-btn" style="background:var(--gold); color:var(--navy)" onclick="copyLink(event)">
            <i class="fas fa-link"></i> رابط التسجيل
        </button>
        <button class="main-btn" style="background:var(--danger); color:white" onclick="logout()">
            <i class="fas fa-sign-out-alt"></i> خروج
        </button>
    </div>
</header>

<div class="container">
    <div class="stats-bar">
        <div class="stat-card"> <span class="stat-val" id="totalCount">0</span> <span class="stat-label">إجمالي الموظفين</span> </div>
        <div class="stat-card" style="border-top-color:var(--danger)"> <span class="stat-val" id="expiredCount" style="color:var(--danger)">0</span> <span class="stat-label">إقامات منتهية</span> </div>
        <div class="stat-card" style="border-top-color:var(--success)"> <span class="stat-val" id="saudiCount" style="color:var(--success)">0</span> <span class="stat-label">مواطنون</span> </div>
        <div class="stat-card" style="border-top-color:var(--gray)"> <span class="stat-val" id="expatCount" style="color:var(--gray)">0</span> <span class="stat-label">مقيمون</span> </div>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="ابحث بالاسم، الهوية، أو الجنسية..." onkeyup="filterData()">
        </div>
        <select id="statusFilter" onchange="filterData()" style="padding: 12px; border-radius: 10px; border: 2px solid #eee; font-family: 'Tajawal'; outline:none; cursor:pointer;">
            <option value="all">كل الموظفين</option>
            <option value="السعودية">سعودي</option>
            <option value="غير سعودي">مقيم (أجنبي)</option>
        </select>
        <div id="resultCount" style="font-size: 0.9rem; color: var(--gray);"></div>
    </div>

    <div class="table-wrapper">
        <div class="scroll-area">
            <table id="empTable">
                <thead>
                    <tr>
                        <th style="text-align:right">الموظف / الهوية</th>
                        <th>الجنسية / الجنس</th>
                        <th>الجوال</th>
                        <th>انتهاء الهوية</th>
                        <th>انتهاء الجواز</th>
                        <th>التأمين والسيارة</th>
                        <th>العمليات</th>
                    </tr>
                </thead>
                <tbody id="empTableBody">
                    <tr><td colspan="7">جاري جلب البيانات...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="editModal" class="modal">
    <div class="modal-content">
        <h3 style="margin-top:0"><i class="fas fa-user-edit"></i> تعديل بيانات الموظف</h3>
        <input type="hidden" id="edit_empId">
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; margin-bottom:20px;">
            <div style="grid-column: span 2;">
                <label style="font-weight:bold; display:block; margin-bottom:5px;">الاسم الكامل</label>
                <input type="text" id="edit_fullName" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd; font-family:'Tajawal'; box-sizing:border-box;">
            </div>
            <div>
                <label style="font-weight:bold; display:block; margin-bottom:5px;">رقم الهوية</label>
                <input type="text" id="edit_idNumber" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd; box-sizing:border-box;">
            </div>
            <div>
                <label style="font-weight:bold; display:block; margin-bottom:5px;">رقم الجوال</label>
                <input type="text" id="edit_phoneNumber" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd; box-sizing:border-box;">
            </div>
        </div>
        <button class="main-btn" style="background:var(--success); color:white; width:100%; justify-content:center" onclick="saveChanges()">حفظ التعديلات</button>
        <button onclick="closeModal()" style="width:100%; background:none; border:none; margin-top:10px; cursor:pointer; color:var(--gray); font-family:'Tajawal'">إلغاء</button>
    </div>
</div>

<div id="toast">تمت العملية بنجاح!</div>

<script>
    let allEmployees = [];
    let currentScopeId = "";

    async function loadData() {
        const urlParams = new URLSearchParams(window.location.search);
        // التعديل هنا: نأخذ الـ uniqueId من الرابط
        currentScopeId = urlParams.get('scope') || localStorage.getItem('scopeId');

        if (!currentScopeId || currentScopeId === "null") { 
            window.location.href = '/manager/login'; 
            return; 
        }
        localStorage.setItem('scopeId', currentScopeId);

        // تحميل اسم المدير من الكاش فوراً
        const cachedName = localStorage.getItem('name_' + currentScopeId);
        if (cachedName) document.getElementById('mgrName').innerText = cachedName;

        try {
            // جلب بيانات النطاق باستخدام الـ uniqueId
            const scopeRes = await fetch(`/manager/api/get-scope-info/${currentScopeId}`);
            if(scopeRes.ok) {
                const scopeData = await scopeRes.json();
                document.getElementById('mgrName').innerText = scopeData.name || "نطاق غير معروف";
                localStorage.setItem('name_' + currentScopeId, scopeData.name);
            } else {
                document.getElementById('mgrName').innerText = "اسم النطاق غير موجود";
            }

            // جلب بيانات الموظفين
            const res = await fetch(`/manager/api/get-employees/${currentScopeId}`);
            if (res.ok) {
                allEmployees = await res.json();
                filterData();
                updateStats();
            } else {
                document.getElementById('empTableBody').innerHTML = '<tr><td colspan="7">لا توجد بيانات موظفين حالياً</td></tr>';
            }
        } catch (e) { 
            document.getElementById('mgrName').innerText = "خطأ في الاتصال";
            document.getElementById('empTableBody').innerHTML = '<tr><td colspan="7">تأكد من حالة السيرفر في Render</td></tr>';
        }
    }

    // إصلاح رابط النسخ ليستخدم الـ uniqueId
    function copyLink(e) {
        // نستخدم currentScopeId مباشرة (مثل SC-F4DEAA)
        const link = `${window.location.origin}/employee/register?scope=${currentScopeId}`;
        
        navigator.clipboard.writeText(link).then(() => {
            const btn = e.currentTarget;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check"></i> تم النسخ!';
            btn.style.background = "#2ed573";
            showToast("تم نسخ رابط التسجيل");
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.style.background = "var(--gold)";
            }, 2000);
        }).catch(() => {
            alert("الرابط هو: " + link);
        });
    }

    function goToLicenses() { 
        window.location.href = `/manager/licenses?scope=${currentScopeId}`; 
    }

    // دوال المساعدة
    function calculateDays(date) { 
        if(!date) return 0; 
        const diff = new Date(date) - new Date();
        return Math.ceil(diff / (1000 * 60 * 60 * 24)); 
    }

    function formatDate(date) { return date ? new Date(date).toLocaleDateString('ar-SA') : "---"; }

    function getExpiryClass(date) {
        if (!date) return "";
        const days = calculateDays(date);
        if (days < 0) return "expired";
        if (days <= 30) return "near-expiry";
        return "valid";
    }

    function renderTable(data) {
        const body = document.getElementById('empTableBody');
        document.getElementById('resultCount').innerText = `عدد النتائج: ${data.length}`;

        if(!data.length) { 
            body.innerHTML = '<tr><td colspan="7" style="padding:50px; color:var(--gray)">لا توجد سجلات مطابقة</td></tr>'; 
            return; 
        }
        
        body.innerHTML = data.map(emp => {
            const genderClass = emp.gender === 'أنثى' ? 'female' : 'male';
            const idDays = calculateDays(emp.idExpiry);
            const hasIns = (emp.hasHealthInsurance === 'true' || emp.hasHealthInsurance === true);
            
            const insHtml = hasIns 
                ? `<span class="${getExpiryClass(emp.insuranceExpiry)}">تأمين: ${formatDate(emp.insuranceExpiry)}</span>` 
                : '<span style="color:#bbb">بدون تأمين</span>';

            const carHtml = emp.hasCarAuthorization 
                ? `<div class="car-info-box"><i class="fas fa-car"></i> ${emp.carType || 'سيارة'} | ${emp.carPlate || ''}</div>`
                : '';

            return `
                <tr>
                    <td style="text-align:right"><strong>${emp.fullName}</strong><br><small style="color:var(--gray)">${emp.idNumber || '---'}</small></td>
                    <td>
                        <span class="badge-nat">${emp.nationality || 'غير محدد'}</span><br>
                        <span class="gender-tag ${genderClass}">${emp.gender || 'ذكر'}</span>
                    </td>
                    <td><a href="tel:${emp.phoneNumber}" style="text-decoration:none; color:inherit">${emp.phoneNumber || '---'}</a></td>
                    <td class="${getExpiryClass(emp.idExpiry)}">
                        ${formatDate(emp.idExpiry)}<br>
                        <small>(${idDays > 0 ? 'باقي ' + idDays : 'منتهي'})</small>
                    </td>
                    <td class="${getExpiryClass(emp.passportExpiry)}">${emp.passportNumber ? formatDate(emp.passportExpiry) : '---'}</td>
                    <td>${insHtml}${carHtml}</td>
                    <td>
                        <div style="display:flex; gap:8px; justify-content:center;">
                            <button class="btn-circle" style="background:#3498db" title="تعديل" onclick="editEmp('${emp._id}')"><i class="fas fa-edit"></i></button>
                            <button class="btn-circle" style="background:var(--danger)" title="حذف" onclick="deleteEmp('${emp._id}', '${emp.fullName}')"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>`;
        }).join('');
    }

    function filterData() {
        const term = document.getElementById('searchInput').value.toLowerCase();
        const filter = document.getElementById('statusFilter').value;
        const filtered = allEmployees.filter(emp => {
            const matchSearch = (emp.fullName || "").toLowerCase().includes(term) || (emp.idNumber || "").includes(term);
            const matchType = filter === 'all' || (filter === 'السعودية' ? emp.nationality === 'السعودية' : emp.nationality !== 'السعودية');
            return matchSearch && matchType;
        });
        renderTable(filtered);
    }

    function updateStats() {
        document.getElementById('totalCount').innerText = allEmployees.length;
        document.getElementById('expiredCount').innerText = allEmployees.filter(e => calculateDays(e.idExpiry) < 0).length;
        document.getElementById('saudiCount').innerText = allEmployees.filter(e => e.nationality === 'السعودية').length;
        document.getElementById('expatCount').innerText = allEmployees.filter(e => e.nationality !== 'السعودية').length;
    }

    function editEmp(id) {
        const emp = allEmployees.find(e => e._id === id);
        if(!emp) return;
        document.getElementById('edit_empId').value = emp._id;
        document.getElementById('edit_fullName').value = emp.fullName;
        document.getElementById('edit_phoneNumber').value = emp.phoneNumber || '';
        document.getElementById('edit_idNumber').value = emp.idNumber || '';
        document.getElementById('editModal').style.display = 'block';
    }

    async function saveChanges() {
        const id = document.getElementById('edit_empId').value;
        const data = {
            fullName: document.getElementById('edit_fullName').value,
            idNumber: document.getElementById('edit_idNumber').value,
            phoneNumber: document.getElementById('edit_phoneNumber').value
        };
        try {
            const res = await fetch(`/manager/api/update-employee/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            if(res.ok) { 
                showToast("تم تحديث البيانات");
                closeModal(); 
                loadData(); 
            }
        } catch (e) { showToast("خطأ في التعديل", true); }
    }

    async function deleteEmp(id, name) {
        if(!confirm(`حذف الموظف: ${name}؟`)) return;
        try {
            const res = await fetch(`/manager/api/delete-employee/${id}`, { method: 'DELETE' });
            if(res.ok) { 
                showToast("تم الحذف");
                loadData(); 
            }
        } catch (e) { showToast("فشل الحذف", true); }
    }

    function closeModal() { document.getElementById('editModal').style.display = 'none'; }
    
    function logout() { 
        localStorage.clear(); 
        window.location.href = '/manager/login'; 
    }

    function showToast(msg, isError = false) {
        const t = document.getElementById('toast');
        t.innerText = msg;
        t.style.background = isError ? "var(--danger)" : "var(--navy)";
        t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 3000);
    }

    window.onload = loadData;
</script>
</body>
</html>