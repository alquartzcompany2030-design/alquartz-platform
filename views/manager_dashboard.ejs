<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | Golden Cloud</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --navy: #0b1d2a; --gold: #ffcc00; --white: #ffffff;
            --danger: #ff4757; --warning: #ffa502; --success: #2ed573;
            --gray: #7f8c8d; --whatsapp: #25D366; --bg: #f8f9fa;
        }
        
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; color: #2d3436; }
        
        header {
            background: var(--navy); color: var(--gold); padding: 15px 25px;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3); position: sticky; top: 0; z-index: 1000;
        }
        
        .container { max-width: 1300px; margin: 0 auto; padding: 20px; }

        /* بطاقات الإحصائيات */
        .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 25px; }
        .stat-card {
            background: white; padding: 20px; border-radius: 15px; text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05); transition: 0.3s; border-top: 5px solid var(--navy);
        }
        .stat-card:hover { transform: translateY(-5px); }
        .stat-val { font-size: 1.8rem; font-weight: 700; display: block; color: var(--navy); }
        .stat-label { font-size: 1rem; color: #636e72; font-weight: 500; }

        /* شريط الأدوات */
        .toolbar {
            background: white; padding: 20px; border-radius: 15px; margin-bottom: 20px;
            display: flex; gap: 15px; align-items: center; box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }
        .search-box { flex: 1; position: relative; }
        .search-box input {
            width: 100%; padding: 12px 45px 12px 15px; border: 2px solid #eee;
            border-radius: 10px; font-size: 1rem; transition: 0.3s; outline: none;
        }
        .search-box i { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: #b2bec3; }

        /* الجدول */
        .table-wrapper { background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
        .scroll-area { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 1000px; }
        thead th { background: var(--navy); color: var(--gold); padding: 18px; font-size: 1rem; font-weight: 700; }
        tbody tr { transition: 0.2s; border-bottom: 1px solid #f1f2f6; }
        td { padding: 15px; text-align: center; vertical-align: middle; }

        .suspended-row { background-color: #f1f2f6; opacity: 0.8; }
        .warning-row { background-color: #fffaf0; }
        .danger-row { background-color: #fff5f5; }

        .action-group { display: flex; gap: 8px; justify-content: center; }
        .btn-circle {
            width: 40px; height: 40px; border-radius: 10px; border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: 0.3s; font-size: 1.1rem; color: white;
        }
        .btn-ed { background: #3498db; }
        .btn-de { background: var(--danger); }

        .main-btn {
            padding: 10px 20px; border-radius: 12px; border: none; font-family: 'Tajawal';
            font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.3s;
        }

        .btn-license { 
            background: transparent; 
            color: var(--gold); 
            border: 1.5px solid var(--gold);
        }
        .btn-license:hover {
            background: var(--gold);
            color: var(--navy);
        }

        /* المودال */
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:3000; backdrop-filter: blur(5px); }
        .modal-content {
            background:white; width:95%; max-width:550px; margin:40px auto; padding:30px;
            border-radius:25px; position: relative;
        }
    </style>
</head>
<body>

<header>
    <div style="display:flex; align-items:center; gap:15px;">
        <i class="fas fa-user-shield fa-2x"></i>
        <h2 style="margin:0">إدارة نطاق: <span id="mgrName" style="color:white">...</span></h2>
    </div>
    <div style="display:flex; gap:10px;">
        <button id="backToMatrix" class="main-btn" style="background:#444; color:white; display:none;" onclick="window.location.href='/admin/matrix'">
            <i class="fas fa-th"></i> العودة للمصفوفة
        </button>

        <button class="main-btn btn-license" onclick="window.location.href='/manager/licenses/page'">
            <i class="fas fa-file-contract"></i> السجلات والرخص
        </button>
        <button class="main-btn" style="background:var(--gold); color:var(--navy)" onclick="copyLink()">
            <i class="fas fa-link"></i> رابط التسجيل
        </button>
        <button class="main-btn" style="background:var(--danger); color:white" onclick="logout()">
            <i class="fas fa-sign-out-alt"></i> خروج
        </button>
    </div>
</header>

<div class="container">
    <div class="stats-bar">
        <div class="stat-card"> <span class="stat-val" id="totalCount">0</span> <span class="stat-label">إجمالي الموظفين</span> </div>
        <div class="stat-card" style="border-top-color:var(--danger)"> <span class="stat-val" id="expiredCount" style="color:var(--danger)">0</span> <span class="stat-label">إقامات منتهية</span> </div>
        <div class="stat-card" style="border-top-color:var(--warning)"> <span class="stat-val" id="warningCount" style="color:var(--warning)">0</span> <span class="stat-label">تجديد قريب</span> </div>
        <div class="stat-card" style="border-top-color:var(--gray)"> <span class="stat-val" id="suspendedCount" style="color:var(--gray)">0</span> <span class="stat-label">حسابات معلقة</span> </div>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="ابحث باسم الموظف أو رقم الإقامة..." onkeyup="filterData()">
        </div>
        <select id="statusFilter" onchange="filterData()" style="padding: 12px; border-radius: 10px; border: 2px solid #eee; font-family: 'Tajawal'; outline:none;">
            <option value="all">كل الحالات</option>
            <option value="active">النشطين فقط</option>
            <option value="suspended">المعلقين فقط</option>
        </select>
    </div>

    <div class="table-wrapper">
        <div class="scroll-area">
            <table id="empTable">
                <thead>
                    <tr>
                        <th>الموظف / الإقامة</th>
                        <th>الجوال</th>
                        <th>المنشأة</th>
                        <th>انتهاء الإقامة</th>
                        <th>الراتب</th>
                        <th>العمليات</th>
                    </tr>
                </thead>
                <tbody id="empTableBody">
                    <tr><td colspan="6">جاري جلب البيانات...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="editModal" class="modal">
    <div class="modal-content">
        <h3><i class="fas fa-user-edit"></i> تعديل بيانات الموظف</h3>
        <input type="hidden" id="edit_empId">
        <div style="margin-bottom:15px">
            <label>الاسم الكامل</label>
            <input type="text" id="edit_fullName" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd; box-sizing: border-box;">
        </div>
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; margin-bottom:15px;">
            <div><label>رقم الجوال</label><input type="text" id="edit_phoneNumber" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd; box-sizing: border-box;"></div>
            <div><label>رقم الإقامة</label><input type="text" id="edit_idNumber" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd; box-sizing: border-box;"></div>
        </div>
        <button class="main-btn" style="background:var(--success); color:white; width:100%; justify-content:center" onclick="saveChanges()">حفظ التعديلات</button>
        <button onclick="closeModal()" style="width:100%; background:none; border:none; margin-top:10px; cursor:pointer; color:var(--gray)">إلغاء</button>
    </div>
</div>

<script>
    let allEmployees = [];
    let currentScopeId = "";

    async function loadData() {
        // 1. التقاط المعرف من الرابط (Query Params) أو من الذاكرة المحلية
        const urlParams = new URLSearchParams(window.location.search);
        const scopeFromURL = urlParams.get('scope');
        const scopeFromStorage = localStorage.getItem('scopeId');
        
        // إذا وجدنا المعرف في الرابط، نقوم بتحديث الذاكرة فوراً (خاص بـ أبو حمزة)
        if (scopeFromURL) {
            localStorage.setItem('scopeId', scopeFromURL);
            localStorage.setItem('userName', "أبو حمزة (إدارة عليا)");
            document.getElementById('backToMatrix').style.display = 'flex';
        }

        currentScopeId = scopeFromURL || scopeFromStorage;
        const managerName = localStorage.getItem('userName') || "مدير النظام";

        // التحقق من وجود المعرف قبل المتابعة لمنع التوجيه الخاطئ
        if (!currentScopeId || currentScopeId === "null") { 
            console.log("❌ لا يوجد معرف نطاق، تحويل لتسجيل الدخول");
            window.location.href = '/manager/login'; 
            return; 
        }

        document.getElementById('mgrName').innerText = managerName;

        try {
            const res = await fetch(`/manager/api/get-employees/${currentScopeId}`);
            if (!res.ok) throw new Error("فشل جلب البيانات من السيرفر");
            
            allEmployees = await res.json();
            filterData();
            updateStats();
        } catch (e) { 
            console.error(e); 
            document.getElementById('empTableBody').innerHTML = '<tr><td colspan="6">تعذر جلب البيانات. تأكد من اتصال السيرفر.</td></tr>';
        }
    }

    function renderTable(data) {
        const body = document.getElementById('empTableBody');
        if(!data || data.length === 0) { body.innerHTML = '<tr><td colspan="6">لا توجد سجلات مطابقة</td></tr>'; return; }
        
        body.innerHTML = data.map(emp => {
            const daysLeft = calculateDays(emp.idExpiry);
            const isSuspended = emp.status === 'suspended';
            let rowClass = isSuspended ? "suspended-row" : (daysLeft < 0 ? "danger-row" : (daysLeft <= 30 ? "warning-row" : ""));
            
            return `
                <tr class="${rowClass}">
                    <td><strong>${emp.fullName}</strong><br><small>${emp.idNumber || '---'}</small></td>
                    <td>${emp.phoneNumber || '---'}</td>
                    <td>${emp.sponsorName || '---'}</td>
                    <td>${formatDate(emp.idExpiry)}<br><small>(${daysLeft} يوم)</small></td>
                    <td>${emp.salary || 0}</td>
                    <td>
                        <div class="action-group">
                            <button class="btn-circle btn-ed" onclick="editEmp('${emp._id}')"><i class="fas fa-edit" title="تعديل"></i></button>
                            <button class="btn-circle btn-de" onclick="deleteEmp('${emp._id}', '${emp.fullName}')"><i class="fas fa-trash" title="حذف"></i></button>
                        </div>
                    </td>
                </tr>`;
        }).join('');
    }

    async function deleteEmp(id, name) {
        if (!confirm(`هل أنت متأكد من حذف الموظف: ${name}؟`)) return;
        try {
            const res = await fetch(`/manager/api/delete-employee/${id}`, { method: 'DELETE' });
            if(res.ok) loadData();
        } catch (err) { alert("حدث خطأ أثناء الحذف"); }
    }

    function editEmp(id) {
        const emp = allEmployees.find(e => e._id === id);
        if(!emp) return;
        document.getElementById('edit_empId').value = emp._id;
        document.getElementById('edit_fullName').value = emp.fullName;
        document.getElementById('edit_phoneNumber').value = emp.phoneNumber || '';
        document.getElementById('edit_idNumber').value = emp.idNumber || '';
        document.getElementById('editModal').style.display = 'block';
    }

    async function saveChanges() {
        const payload = {
            empId: document.getElementById('edit_empId').value,
            fullName: document.getElementById('edit_fullName').value,
            phoneNumber: document.getElementById('edit_phoneNumber').value,
            idNumber: document.getElementById('edit_idNumber').value
        };
        try {
            const res = await fetch('/manager/api/update-employee', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(payload)
            });
            if(res.ok) { closeModal(); loadData(); }
        } catch (err) { alert("فشل حفظ التعديلات"); }
    }

    function filterData() {
        const term = document.getElementById('searchInput').value.toLowerCase();
        const stat = document.getElementById('statusFilter').value;
        const filtered = allEmployees.filter(emp => {
            const matchSearch = (emp.fullName || "").toLowerCase().includes(term) || (emp.idNumber && emp.idNumber.includes(term));
            const matchStatus = stat === 'all' || emp.status === stat;
            return matchSearch && matchStatus;
        });
        renderTable(filtered);
    }

    function calculateDays(date) { 
        if(!date) return 0; 
        const diff = new Date(date) - new Date();
        return Math.ceil(diff / (1000 * 60 * 60 * 24)); 
    }

    function formatDate(date) { 
        return date ? new Date(date).toLocaleDateString('ar-SA') : "---"; 
    }

    function closeModal() { 
        document.getElementById('editModal').style.display = 'none'; 
    }
    
    function updateStats() {
        document.getElementById('totalCount').innerText = allEmployees.length;
        document.getElementById('expiredCount').innerText = allEmployees.filter(e => calculateDays(e.idExpiry) < 0).length;
        document.getElementById('warningCount').innerText = allEmployees.filter(e => { 
            const d = calculateDays(e.idExpiry); 
            return d >= 0 && d <= 30; 
        }).length;
        document.getElementById('suspendedCount').innerText = allEmployees.filter(e => e.status === 'suspended').length;
    }

    function logout() { 
        localStorage.clear(); 
        window.location.href = '/manager/login'; 
    }

    function copyLink() {
        if(!currentScopeId) return alert('خطأ: المعرف غير موجود');
        const link = window.location.origin + '/employee/register/' + currentScopeId;
        navigator.clipboard.writeText(link)
            .then(() => alert('✅ تم نسخ رابط تسجيل الموظفين بنجاح'))
            .catch(() => alert('❌ فشل النسخ تلقائياً'));
    }

    // تشغيل جلب البيانات عند التحميل
    loadData();
</script>
</body>
</html>