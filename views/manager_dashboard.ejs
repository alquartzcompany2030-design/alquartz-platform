<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | Golden Cloud Server</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        :root {
            --navy: #0b1d2a; --gold: #ffcc00; --white: #ffffff;
            --danger: #ff4757; --warning: #ffa502; --success: #2ed573;
            --gray: #7f8c8d; --bg: #f0f2f5; --shadow: 0 8px 30px rgba(0,0,0,0.12);
            --glass-blue: rgba(235, 245, 255, 0.7); /* لون هادئ */
            --glass-green: rgba(232, 247, 238, 0.8); /* لون هادئ */
        }
        
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; color: #2d3436; }
        
        header {
            background: var(--navy); color: var(--gold); padding: 15px 30px;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4); position: sticky; top: 0; z-index: 1000;
        }
        
        .container { max-width: 1500px; margin: 0 auto; padding: 25px; }

        .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card {
            background: white; padding: 20px; border-radius: 18px; text-align: center;
            box-shadow: var(--shadow); border-bottom: 5px solid var(--navy);
        }
        .stat-val { font-size: 2.2rem; font-weight: 800; color: var(--navy); display: block; }
        .stat-label { font-weight: 500; color: var(--gray); font-size: 1rem; }

        .toolbar {
            background: white; padding: 20px; border-radius: 15px; margin-bottom: 25px;
            display: flex; gap: 15px; align-items: center; box-shadow: var(--shadow); flex-wrap: wrap;
        }
        .search-box { flex: 2; position: relative; min-width: 300px; }
        .search-box input {
            width: 100%; padding: 14px 45px 14px 15px; border: 2px solid #eef0f2;
            border-radius: 12px; font-size: 1rem; outline: none; font-family: 'Tajawal'; transition: 0.3s;
        }
        .search-box i { position: absolute; right: 18px; top: 50%; transform: translateY(-50%); color: var(--navy); }

        .main-btn { padding: 12px 22px; border-radius: 12px; border: none; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 10px; font-family: 'Tajawal'; transition: 0.3s; }

        .table-wrapper { background: white; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
        table { width: 100%; border-collapse: collapse; }
        thead th { background: var(--navy); color: var(--gold); padding: 20px; font-size: 0.95rem; }
        td { padding: 15px; text-align: center; border-bottom: 1px solid #edf2f7; }

        /* أزرار الإجراءات في الجدول */
        .action-btns { display: flex; gap: 8px; justify-content: center; }
        .btn-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; color: white; transition: 0.2s; font-size: 1rem; text-decoration: none; }
        .btn-view { background: #3498db; }
        .btn-whatsapp { background: #2ed573; }
        .btn-delete { background: var(--danger); }

        /* النافذة المنبثقة */
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,10,20,0.85); z-index:3000; backdrop-filter: blur(8px); }
        .modal-content { 
            background: #fff; width:90%; max-width:1100px; margin:2vh auto; padding:25px; 
            border-radius:25px; position: relative; max-height: 95vh; overflow-y: auto;
        }
        
        .matrix-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-top: 20px; }
        .info-card { border-radius: 15px; padding: 15px; border: 1px solid rgba(0,0,0,0.03); }
        .card-blue { background: var(--glass-blue); border-top: 4px solid #3498db; }
        .card-green { background: var(--glass-green); border-top: 4px solid var(--success); }
        
        .card-title { display: flex; align-items: center; gap: 8px; color: var(--navy); font-weight: 700; margin-bottom: 12px; font-size: 1rem; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 8px; }
        .data-row { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.88rem; }
        .data-label { color: #576574; }
        .data-val { font-weight: 700; color: var(--navy); text-align: left; }

        #toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: var(--navy); color: var(--gold); padding: 15px 40px; border-radius: 50px; display: none; z-index: 5000; }

        @media (max-width: 900px) { .matrix-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 600px) { .matrix-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

<header>
    <div style="display:flex; align-items:center; gap:15px;">
        <i class="fas fa-cloud fa-2x"></i>
        <h2 style="margin:0">Golden Cloud Server | <span id="scopeName" style="color:white; font-weight:400">جاري التحميل...</span></h2>
    </div>
    <div style="display:flex; gap:12px;">
        <button class="main-btn" style="background:var(--gold); color:var(--navy)" onclick="copyLink()">
            <i class="fas fa-link"></i> رابط التسجيل
        </button>
        <button class="main-btn" style="background:var(--danger); color:white" onclick="logout()">
            <i class="fas fa-sign-out-alt"></i> خروج
        </button>
    </div>
</header>

<div class="container">
    <div class="stats-bar" id="statsBar">
        <div class="stat-card">
            <span class="stat-val" id="totalCount">0</span>
            <span class="stat-label">إجمالي الكادر</span>
        </div>
        <div class="stat-card" style="border-color:var(--danger)">
            <span class="stat-val" id="expiredCount" style="color:var(--danger)">0</span>
            <span class="stat-label">هويات منتهية</span>
        </div>
        <div class="stat-card" style="border-color:var(--warning)">
            <span class="stat-val" id="carCount" style="color:var(--warning)">0</span>
            <span class="stat-label">سيارات العهدة</span>
        </div>
        <div class="stat-card" style="border-color:var(--success)">
            <span class="stat-val" id="insurCount" style="color:var(--success)">0</span>
            <span class="stat-label">التغطية الصحية</span>
        </div>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="ابحث بالاسم، الهوية، الجوال أو الفرع..." onkeyup="filterData()">
        </div>
        <button class="main-btn" style="background:#1d7a46; color:white;" onclick="exportFullExcel()">
            <i class="fas fa-file-excel"></i> تصدير (Excel)
        </button>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>الموظف</th>
                    <th>رقم الهوية</th>
                    <th>الجنسية</th>
                    <th>رقم الجوال</th>
                    <th>انتهاء الهوية</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody id="empTableBody">
                <tr><td colspan="6">جاري جلب البيانات من السيرفر...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div id="viewModal" class="modal" onclick="if(event.target==this) closeModal()">
    <div class="modal-content">
        <div style="display:flex; justify-content:space-between; align-items:center; border-bottom: 2px solid #eee; padding-bottom: 15px;">
            <h2 style="margin:0; color:var(--navy); font-size: 1.3rem;"><i class="fas fa-id-card-alt"></i> تفاصيل ملف الموظف الرقمي</h2>
            <button onclick="closeModal()" style="border:none; background:none; cursor:pointer; font-size:2rem; color:var(--gray)">&times;</button>
        </div>
        
        <div id="modalDetails" class="matrix-grid"></div>

        <div style="margin-top:25px; text-align: center;">
            <button class="main-btn" style="background:var(--navy); color:white; margin: 0 auto;" onclick="closeModal()">إغلاق المعاينة</button>
        </div>
    </div>
</div>

<div id="toast"></div>

<script>
    let allEmployees = [];
    const currentScopeId = new URLSearchParams(window.location.search).get('scope') || localStorage.getItem('scopeId');

    async function loadData() {
        if (!currentScopeId) return;
        try {
            const res = await fetch(`/manager/api/get-employees/${currentScopeId}`);
            if (res.ok) {
                const data = await res.json();
                allEmployees = data.employees;
                document.getElementById('scopeName').innerText = data.scopeName || "نطاق عام";
                renderTable(allEmployees);
                updateStats();
            }
        } catch (e) { showToast("خطأ في الاتصال بالسيرفر", true); }
    }

    function renderTable(data) {
        const body = document.getElementById('empTableBody');
        if(data.length === 0) { body.innerHTML = '<tr><td colspan="6">لا يوجد موظفين مسجلين حالياً</td></tr>'; return; }
        
        body.innerHTML = data.map(emp => {
            const waPhone = emp.phoneNumber.replace(/\s+/g, '').replace('+', '');
            return `
            <tr>
                <td><strong>${emp.fullName}</strong></td>
                <td><code style="background:#f0f0f0; padding:4px 8px; border-radius:5px">${emp.idNumber}</code></td>
                <td>${emp.nationality || '---'}</td>
                <td>${emp.phoneNumber}</td>
                <td style="color:${isExpired(emp.idExpiry) ? 'var(--danger)' : '#27ae60'}">${emp.idExpiry || '---'}</td>
                <td>
                    <div class="action-btns">
                        <button class="btn-icon btn-view" onclick="viewDetails('${emp._id}')" title="معاينة"><i class="fas fa-eye"></i></button>
                        <a href="https://wa.me/${waPhone}" target="_blank" class="btn-icon btn-whatsapp" title="واتساب"><i class="fab fa-whatsapp"></i></a>
                        <button class="btn-icon btn-delete" onclick="deleteEmp('${emp._id}')" title="حذف"><i class="fas fa-trash-alt"></i></button>
                    </div>
                </td>
            </tr>
        `}).join('');
    }

    async function deleteEmp(id) {
        if(!confirm("هل أنت متأكد من حذف هذا الموظف؟ لا يمكن التراجع عن هذا الإجراء.")) return;
        try {
            const res = await fetch(`/manager/api/delete-employee/${id}`, { method: 'DELETE' });
            if(res.ok) {
                showToast("تم الحذف بنجاح");
                loadData();
            }
        } catch(e) { showToast("فشل الحذف", true); }
    }

    function viewDetails(id) {
        const emp = allEmployees.find(e => e._id === id);
        if(!emp) return;

        const blocks = [
            { t: "الهوية الوطنية", i: "id-card", c: "card-blue", d: { "الرقم": emp.idNumber, "الانتهاء": emp.idExpiry, "الإصدار": emp.idIssuePlace } },
            { t: "بيانات التواصل", i: "phone", c: "card-green", d: { "الجوال": emp.phoneNumber, "المدينة": emp.city, "الطوارئ": emp.emergencyContact } },
            { t: "العمل والفرع", i: "briefcase", c: "card-blue", d: { "المسمى": emp.jobTitle, "الفرع": emp.branch, "المباشرة": emp.joinDate } },
            { t: "جواز السفر", i: "passport", c: "card-green", d: { "الرقم": emp.passportNumber, "الانتهاء": emp.passportExpiry, "البلد": emp.passportIssueCountry } },
            { t: "المركبة والعهدة", i: "car", c: "card-blue", d: { "اللوحة": emp.carPlate, "النوع": emp.carType, "الموديل": emp.carYear } },
            { t: "التأمين الصحي", i: "heart-pulse", c: "card-green", d: { "الحالة": emp.hasHealthInsurance ? "نشط" : "غير مؤمن", "الشركة": emp.insuranceCompany, "البوليصة": emp.insuranceNo } },
            { t: "رخصة القيادة", i: "driver-card", c: "card-blue", d: { "الرخصة": emp.hasDrivingLicense ? "متوفرة" : "لا يوجد", "الفئة": emp.licenseClass, "التفويض": emp.hasCarAuthorization ? "يوجد" : "لا يوجد" } },
            { t: "البيانات الشخصية", i: "user", c: "card-green", d: { "الجنسية": emp.nationality, "الحالة": emp.familyStatus, "العائلة": emp.hasFamilyInKSA ? "بالمملكة" : "خارج المملكة" } },
            { t: "ملاحظات إضافية", i: "sticky-note", c: "card-blue", d: { "البريد": emp.email || "---", "ملاحظات": emp.notes || "لا يوجد" } }
        ];

        document.getElementById('modalDetails').innerHTML = blocks.map(b => `
            <div class="info-card ${b.c}">
                <div class="card-title"><i class="fas fa-${b.i}"></i> ${b.t}</div>
                ${Object.entries(b.d).map(([l, v]) => `
                    <div class="data-row"><span class="data-label">${l}:</span><span class="data-val">${v || '---'}</span></div>
                `).join('')}
            </div>
        `).join('');

        document.getElementById('viewModal').style.display = 'block';
    }

    function exportFullExcel() {
        if(allEmployees.length === 0) return;
        const ws = XLSX.utils.json_to_sheet(allEmployees);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Employees");
        XLSX.writeFile(wb, `Data_Export_${new Date().toLocaleDateString()}.xlsx`);
    }

    function isExpired(date) { return date && new Date(date) < new Date(); }

    function updateStats() {
        document.getElementById('totalCount').innerText = allEmployees.length;
        document.getElementById('expiredCount').innerText = allEmployees.filter(e => isExpired(e.idExpiry)).length;
        document.getElementById('insurCount').innerText = allEmployees.filter(e => e.hasHealthInsurance).length;
        document.getElementById('carCount').innerText = allEmployees.filter(e => e.carPlate).length;
    }

    function filterData() {
        const term = document.getElementById('searchInput').value.toLowerCase();
        const filtered = allEmployees.filter(e => 
            e.fullName.toLowerCase().includes(term) || 
            e.idNumber.includes(term) || 
            (e.branch && e.branch.toLowerCase().includes(term))
        );
        renderTable(filtered);
    }

    function showToast(msg, err = false) {
        const t = document.getElementById('toast');
        t.innerText = msg; t.style.background = err ? "#e74c3c" : "#0b1d2a";
        t.style.display = 'block'; setTimeout(() => t.style.display = 'none', 3000);
    }

    function copyLink() {
        const link = `${window.location.origin}/employee/register?scope=${currentScopeId}`;
        navigator.clipboard.writeText(link);
        showToast("تم نسخ رابط التسجيل بنجاح");
    }

    function logout() { localStorage.clear(); window.location.href = '/manager/login'; }
    function closeModal() { document.getElementById('viewModal').style.display = 'none'; }
    window.onload = loadData;
</script>
</body>
</html>