<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | Golden Cloud Server</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        :root {
            --navy: #0b1d2a; --gold: #ffcc00; --white: #ffffff;
            --danger: #ff4757; --warning: #ffa502; --success: #2ed573;
            --info: #3498db; --gray-light: #f8f9fa; --gray-dark: #2d3436;
            --shadow-sm: 0 2px 10px rgba(0,0,0,0.05); --shadow-lg: 0 10px 40px rgba(0,0,0,0.15);
        }

        * { box-sizing: border-box; transition: all 0.2s ease; }
        body { font-family: 'Tajawal', sans-serif; background-color: #f0f2f5; margin: 0; color: var(--gray-dark); }

        header {
            background: linear-gradient(135deg, var(--navy) 0%, #162e3e 100%);
            color: var(--gold); padding: 15px 40px; display: flex;
            justify-content: space-between; align-items: center;
            box-shadow: 0 4px 25px rgba(0,0,0,0.3); position: sticky; top: 0; z-index: 1000;
        }

        .logo-section { display: flex; align-items: center; gap: 20px; }
        .scope-badge { 
            background: rgba(255,255,255,0.1); padding: 5px 15px; border-radius: 50px; 
            color: #fff; font-weight: 700; border: 1px solid var(--gold);
        }

        .container { max-width: 1600px; margin: 0 auto; padding: 30px; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; margin-bottom: 40px; }
        .stat-card { background: var(--white); padding: 25px; border-radius: 20px; display: flex; align-items: center; gap: 20px; box-shadow: var(--shadow-sm); border-right: 6px solid var(--navy); }

        .toolbar { background: var(--white); padding: 25px; border-radius: 20px; margin-bottom: 30px; display: flex; gap: 15px; align-items: center; box-shadow: var(--shadow-sm); flex-wrap: wrap; }
        .search-wrapper { flex: 1; position: relative; min-width: 300px; }
        .search-wrapper input { width: 100%; padding: 15px 50px 15px 20px; border: 2px solid #eee; border-radius: 15px; font-size: 1rem; font-family: inherit; }
        .search-wrapper i { position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: var(--navy); }

        .btn { padding: 12px 20px; border-radius: 12px; border: none; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; font-family: inherit; text-decoration: none; font-size: 0.9rem; }
        .btn-excel { background: #1d7a46; color: white; }
        .btn-link { background: var(--gold); color: var(--navy); }
        .btn-danger { background: var(--danger); color: white; }
        .btn-whatsapp { background: #25D366; color: white; }

        .table-card { background: var(--white); border-radius: 25px; box-shadow: var(--shadow-sm); overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 1000px; }
        thead th { background: var(--navy); color: var(--gold); padding: 20px; }
        td { padding: 15px; text-align: center; border-bottom: 1px solid #f0f0f0; }

        /* Modal Styles */
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:2000; backdrop-filter: blur(5px); }
        .modal-content { background: #fff; width: 90%; max-width: 800px; margin: 5vh auto; border-radius: 20px; overflow: hidden; }
        .modal-header { padding: 20px; background: var(--navy); color: var(--gold); display: flex; justify-content: space-between; align-items: center; }
        .modal-body { padding: 25px; }

        .edit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 15px; }
        .form-group label { font-weight: 700; color: var(--navy); }
        .form-group input, .form-group select { padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; }

        #toast { position: fixed; bottom: 30px; right: 30px; padding: 15px 30px; border-radius: 12px; display: none; z-index: 9999; color: white; box-shadow: var(--shadow-lg); }
    </style>
</head>
<body>

<header>
    <div class="logo-section">
        <i class="fas fa-server fa-2x"></i>
        <div>
            <h2 style="margin:0">Golden Cloud</h2>
            <div id="scopeNameDisplay" class="scope-badge">جاري التحميل...</div>
        </div>
    </div>
    <div style="display: flex; gap: 10px;">
        <button class="btn btn-link" onclick="copyRegLink()"><i class="fas fa-user-plus"></i> رابط التسجيل</button>
        <button class="btn btn-danger" onclick="logout()"><i class="fas fa-power-off"></i> خروج</button>
    </div>
</header>

<div class="container">
    <div class="stats-grid" id="statsContainer">
        </div>

    <div class="toolbar">
        <div class="search-wrapper">
            <i class="fas fa-search"></i>
            <input type="text" id="mainSearch" placeholder="ابحث بالاسم أو الهوية..." onkeyup="handleSearch()">
        </div>
        <button class="btn btn-excel" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> تصدير إكسل</button>
        <button class="btn" style="background: var(--navy); color:white" onclick="init()"><i class="fas fa-sync"></i> تحديث</button>
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>الموظف</th>
                    <th>الهوية</th>
                    <th>الجوال</th>
                    <th>انتهاء الهوية</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody id="employeeTable">
                <tr><td colspan="6">جاري جلب البيانات...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div id="editModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>تحديث بيانات الموظف</h3>
            <button onclick="closeModal()" style="background:none; border:none; color:#fff; font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>
        <div class="modal-body">
            <form id="editForm">
                <input type="hidden" id="edit_id">
                <div class="edit-grid">
                    <div class="form-group">
                        <label>الاسم الكامل</label>
                        <input type="text" id="edit_fullName" required>
                    </div>
                    <div class="form-group">
                        <label>رقم الجوال</label>
                        <input type="text" id="edit_phoneNumber" required>
                    </div>
                    <div class="form-group">
                        <label>تاريخ انتهاء الهوية</label>
                        <input type="date" id="edit_idExpiry" required>
                    </div>
                    <div class="form-group">
                        <label>تاريخ انتهاء الجواز</label>
                        <input type="date" id="edit_passportExpiry">
                    </div>
                    <div class="form-group">
                        <label>رقم اللوحة (العهدة)</label>
                        <input type="text" id="edit_carPlate">
                    </div>
                    <div class="form-group">
                        <label>التأمين الطبي</label>
                        <select id="edit_hasHealthInsurance">
                            <option value="true">موجود</option>
                            <option value="false">غير موجود</option>
                        </select>
                    </div>
                </div>
                <div style="margin-top: 20px; display: flex; gap: 10px;">
                    <button type="submit" class="btn" style="background: var(--success); color:white; flex:1">حفظ التغييرات</button>
                    <button type="button" class="btn" onclick="closeModal()" style="background: #eee; flex:1">إلغاء</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="toast"></div>

<script>
    let rawData = [];
    const urlParams = new URLSearchParams(window.location.search);
    const scopeId = urlParams.get('scope');

    async function init() {
        if(!scopeId) return alert("كود النطاق مفقود");
        await fetchScopeInfo();
        await loadEmployees();
    }

    async function fetchScopeInfo() {
        try {
            const res = await fetch(`/manager/api/get-scope-info/${scopeId}`);
            const data = await res.json();
            document.getElementById('scopeNameDisplay').innerText = data.name || "نطاق رئيسي";
        } catch (e) { console.error(e); }
    }

    async function loadEmployees() {
        try {
            const res = await fetch(`/manager/api/get-employees/${scopeId}`);
            rawData = await res.json();
            renderTable(rawData);
            renderStats(rawData);
        } catch (e) {
            showToast("فشل تحديث البيانات", true);
        }
    }

    function renderTable(data) {
        const tbody = document.getElementById('employeeTable');
        tbody.innerHTML = data.map(emp => {
            const isExp = emp.idExpiry && new Date(emp.idExpiry) < new Date();
            const waLink = `https://wa.me/${emp.phoneNumber?.replace(/\D/g,'')}?text=تحية طيبة، نود تذكيرك بتحديث بياناتك لدى غولدن كلاود`;
            
            return `
                <tr>
                    <td><b>${emp.fullName}</b><br><small>${emp.jobTitle || 'موظف'}</small></td>
                    <td><code>${emp.idNumber}</code></td>
                    <td>${emp.phoneNumber}</td>
                    <td style="color:${isExp ? 'red' : 'green'}; font-weight:bold">${new Date(emp.idExpiry).toLocaleDateString('en-GB')}</td>
                    <td><i class="fas fa-shield-alt" style="color:${emp.hasHealthInsurance ? '#2ed573' : '#ccc'}"></i></td>
                    <td>
                        <div style="display:flex; gap:5px; justify-content:center">
                            <button class="btn btn-whatsapp" onclick="window.open('${waLink}')"><i class="fab fa-whatsapp"></i></button>
                            <button class="btn" style="background:var(--info); color:white" onclick="openEditModal('${emp._id}')"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-danger" onclick="deleteEmployee('${emp._id}')"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            `;
        }).join('');
    }

    // وظيفة الحذف
    async function deleteEmployee(id) {
        if(!confirm("هل أنت متأكد من حذف هذا الموظف نهائياً؟")) return;
        try {
            const res = await fetch(`/manager/api/delete-employee/${id}`, { method: 'DELETE' });
            if(res.ok) {
                showToast("تم الحذف بنجاح");
                loadEmployees();
            }
        } catch (e) { showToast("فشل الحذف", true); }
    }

    // وظيفة التعديل
    function openEditModal(id) {
        const emp = rawData.find(e => e._id === id);
        if(!emp) return;
        
        document.getElementById('edit_id').value = emp._id;
        document.getElementById('edit_fullName').value = emp.fullName;
        document.getElementById('edit_phoneNumber').value = emp.phoneNumber;
        document.getElementById('edit_idExpiry').value = emp.idExpiry ? emp.idExpiry.split('T')[0] : '';
        document.getElementById('edit_passportExpiry').value = emp.passportExpiry ? emp.passportExpiry.split('T')[0] : '';
        document.getElementById('edit_carPlate').value = emp.carPlate || '';
        document.getElementById('edit_hasHealthInsurance').value = emp.hasHealthInsurance.toString();
        
        document.getElementById('editModal').style.display = 'block';
    }

    document.getElementById('editForm').onsubmit = async (e) => {
        e.preventDefault();
        const id = document.getElementById('edit_id').value;
        const updatedData = {
            fullName: document.getElementById('edit_fullName').value,
            phoneNumber: document.getElementById('edit_phoneNumber').value,
            idExpiry: document.getElementById('edit_idExpiry').value,
            passportExpiry: document.getElementById('edit_passportExpiry').value,
            carPlate: document.getElementById('edit_carPlate').value,
            hasHealthInsurance: document.getElementById('edit_hasHealthInsurance').value === 'true'
        };

        try {
            const res = await fetch(`/manager/api/update-employee/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(updatedData)
            });
            if(res.ok) {
                showToast("تم تحديث البيانات بنجاح ✅");
                closeModal();
                loadEmployees();
            }
        } catch (e) { showToast("فشل التحديث", true); }
    };

    function renderStats(data) {
        const expiredCount = data.filter(e => new Date(e.idExpiry) < new Date()).length;
        document.getElementById('statsContainer').innerHTML = `
            <div class="stat-card"><div><h3>الكادر</h3><div class="value">${data.length}</div></div></div>
            <div class="stat-card" style="border-right-color:var(--danger)"><div><h3>هويات منتهية</h3><div class="value">${expiredCount}</div></div></div>
            <div class="stat-card" style="border-right-color:var(--success)"><div><h3>تأمين نشط</h3><div class="value">${data.filter(e => e.hasHealthInsurance).length}</div></div></div>
            <div class="stat-card" style="border-right-color:var(--warning)"><div><h3>سيارات عهدة</h3><div class="value">${data.filter(e => e.carPlate).length}</div></div></div>
        `;
    }

    function handleSearch() {
        const term = document.getElementById('mainSearch').value.toLowerCase();
        renderTable(rawData.filter(e => e.fullName.toLowerCase().includes(term) || e.idNumber.includes(term)));
    }

    function showToast(msg, isError = false) {
        const t = document.getElementById('toast');
        t.innerText = msg;
        t.style.background = isError ? 'var(--danger)' : 'var(--navy)';
        t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 3000);
    }

    function closeModal() { document.getElementById('editModal').style.display = 'none'; }
    function copyRegLink() {
        navigator.clipboard.writeText(`${window.location.origin}/employee/register?scope=${scopeId}`);
        showToast("تم نسخ رابط التسجيل");
    }
    function logout() { window.location.href = '/'; }

    window.onload = init;
</script>
</body>
</html>