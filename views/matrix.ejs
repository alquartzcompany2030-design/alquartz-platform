<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مصفوفة المنشآت الموحدة | الكوارتز</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { 
            --navy: #0d2d4d; --gold: #ffcc00; --teal: #1abc9c; 
            --red: #e74c3c; --gray: #777; --bg: #f4f7f6;
            --saudi: #27ae60; --expat: #2980b9;
        }
        
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; padding: 20px; }
        
        .header { 
            display: flex; justify-content: space-between; align-items: center; 
            margin-bottom: 30px; background: var(--navy); color: white; 
            padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 20px;
        }

        .org-card {
            background: white; border-radius: 15px; padding: 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05); border-top: 5px solid var(--navy);
            transition: 0.3s ease; cursor: pointer; position: relative;
            display: flex; flex-direction: column;
        }
        .org-card:hover { transform: translateY(-5px); box-shadow: 0 8px 20px rgba(0,0,0,0.1); border-top-color: var(--gold); }
        
        .alert-pulse {
            position: absolute; top: 12px; left: 12px; width: 12px; height: 12px;
            background: var(--red); border-radius: 50%; animation: blink 1.2s infinite;
        }

        .org-title { margin: 0; color: var(--navy); font-size: 1.1rem; font-weight: 700; text-align: center; }
        .org-id { color: #999; font-size: 0.8rem; display: block; margin-bottom: 15px; text-align: center; }

        .worker-section {
            background: #fcfcfc; border: 1px solid #eee; border-radius: 12px;
            padding: 12px; margin-bottom: 15px;
        }
        .worker-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; }
        .worker-row:first-child { border-bottom: 1px dashed #ddd; margin-bottom: 5px; }
        
        .main-stat { flex: 1; text-align: center; }
        .sub-stats { flex: 1; display: flex; justify-content: space-around; border-right: 1px solid #eee; }
        
        .w-label { font-size: 0.75rem; color: var(--gray); display: block; }
        .w-count { font-weight: bold; font-size: 1.2rem; }
        .sub-count { font-size: 0.9rem; color: #555; }

        .count-saudi { color: var(--saudi); }
        .count-expat { color: var(--expat); }

        .footer-info { font-size: 0.85rem; display: flex; align-items: center; justify-content: center; gap: 8px; padding-top: 10px; border-top: 1px solid #f0f0f0; }
        .text-danger { color: var(--red) !important; font-weight: bold; }

        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }

        .btn-matrix-back {
            color:white; text-decoration:none; background:rgba(255,255,255,0.1); 
            padding:10px 20px; border-radius:8px; transition: 0.3s; font-weight: bold;
        }
        .btn-matrix-back:hover { background: var(--gold); color: var(--navy); }
    </style>
</head>
<body>

    <div class="header">
        <div>
            <h2 style="margin:0;"><i class="fas fa-layer-group"></i> مصفوفة إدارة المنشآت</h2>
            <p style="margin:5px 0 0; font-size:0.9rem; color:var(--gold);">نظام الرصد الذكي | أبو حمزة</p>
        </div>
        <a href="/admin/dashboard" class="btn-matrix-back">
            <i class="fas fa-chart-line"></i> لوحة التحكم
        </a>
    </div>

    <div class="grid-container" id="matrixGrid">
        <div style="grid-column: 1 / -1; text-align: center; padding: 50px;">
            <i class="fas fa-spinner fa-spin fa-2x" style="color: var(--navy);"></i>
            <p>جاري تحميل المصفوفة...</p>
        </div>
    </div>

    <script>
        // 1. تعريف وظيفة الانتقال مع حفظ النطاق في الذاكرة
        function goToDashboard(scopeId) {
            if (!scopeId) return;
            // حفظ النطاق لضمان العودة إليه في حال تعطل الرابط
            localStorage.setItem('last_active_scope', scopeId);
            window.location.href = `/manager/dashboard?scope=${scopeId}`;
        }

        // 2. دالة جلب البيانات مع معالجة الانقطاع
        async function loadMatrix() {
            const grid = document.getElementById('matrixGrid');
            try {
                // استدعاء البيانات من السيرفر (تأكد من المسار الصحيح في مشروعك)
                const response = await fetch('/api/admin/get-all-orgs'); 
                if (!response.ok) throw new Error("Server Down");
                
                const orgs = await response.json();
                renderOrgs(orgs);

            } catch (error) {
                console.error("Matrix Load Error:", error);
                // إظهار تنبيه في حال فشل الاتصال بقاعدة البيانات
                grid.innerHTML = `
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px; background: #fff; border-radius: 15px; border: 2px dashed var(--red);">
                        <i class="fas fa-plug-circle-xmark fa-3x" style="color: var(--red); margin-bottom: 15px;"></i>
                        <h3 style="color: var(--navy);">عذراً، تعذر الاتصال بالسيرفر حالياً</h3>
                        <p>يرجى التحقق من اتصال الإنترنت أو محاولة تحديث الصفحة.</p>
                        <button onclick="location.reload()" style="padding: 10px 25px; background: var(--navy); color: white; border: none; border-radius: 8px; cursor: pointer;">
                            <i class="fas fa-sync"></i> إعادة المحاولة
                        </button>
                    </div>
                `;
            }
        }

        // 3. دالة رسم البطاقات
        function renderOrgs(orgs) {
            const grid = document.getElementById('matrixGrid');
            if (!orgs || orgs.length === 0) {
                grid.innerHTML = `<div style="grid-column: 1 / -1; text-align: center; padding: 80px;"><h3>لا توجد منشآت نشطة</h3></div>`;
                return;
            }

            grid.innerHTML = orgs.map(org => `
                <div class="org-card" onclick="goToDashboard('${org.uniqueId}')">
                    ${org.expiredLicenses > 0 ? '<div class="alert-pulse" title="يوجد رخص منتهية"></div>' : ''}
                    
                    <h3 class="org-title">${org.name}</h3>
                    <span class="org-id">ID: ${org.uniqueId}</span>

                    <div class="worker-section">
                        <div class="worker-row">
                            <div class="main-stat">
                                <span class="w-label">سعودي</span>
                                <span class="w-count count-saudi">${org.saudiWorkers || 0}</span>
                            </div>
                            <div class="sub-stats">
                                <div><span class="w-label">♂</span><span class="sub-count">${org.saudiMale || 0}</span></div>
                                <div><span class="w-label">♀</span><span class="sub-count">${org.saudiFemale || 0}</span></div>
                            </div>
                        </div>
                        <div class="worker-row">
                            <div class="main-stat">
                                <span class="w-label">مقيم</span>
                                <span class="w-count count-expat">${org.expatWorkers || 0}</span>
                            </div>
                            <div class="sub-stats">
                                <div><span class="w-label">♂</span><span class="sub-count">${org.expatMale || 0}</span></div>
                                <div><span class="w-label">♀</span><span class="sub-count">${org.expatFemale || 0}</span></div>
                            </div>
                        </div>
                    </div>

                    <div class="footer-info ${org.expiredLicenses > 0 ? 'text-danger' : ''}">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>رخص منتهية: ${org.expiredLicenses || 0}</span>
                    </div>
                </div>
            `).join('');
        }

        // 4. معالجة حدث العودة للخلف (Back Button)
        window.onpageshow = function(event) {
            if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
                loadMatrix();
            }
        };

        window.onload = loadMatrix;
    </script>
</body>
</html>