<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | منصة أبو حمزة الذكية</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --navy: #0b1d2a; --gold: #ffcc00; --white: #ffffff;
            --danger: #ff4757; --warning: #ffa502; --success: #2ed573;
            --gray: #7f8c8d; --bg: #f8f9fa; --shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; color: #2d3436; overflow-x: hidden; }
        
        header {
            background: var(--navy); color: var(--gold); padding: 15px 25px;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3); position: sticky; top: 0; z-index: 1000;
        }
        
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }

        .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 15px; margin-bottom: 25px; }
        .stat-card {
            background: white; padding: 20px; border-radius: 15px; text-align: center;
            box-shadow: var(--shadow); transition: 0.3s; border-top: 5px solid var(--navy);
            position: relative; overflow: hidden;
        }
        .stat-card:hover { transform: translateY(-5px); }
        .stat-val { font-size: 2.2rem; font-weight: 700; display: block; color: var(--navy); margin-bottom: 5px; }
        .stat-label { font-size: 1rem; color: #636e72; font-weight: 500; }
        .stat-icon { position: absolute; left: -10px; bottom: -10px; font-size: 4rem; opacity: 0.05; color: var(--navy); }

        .toolbar {
            background: white; padding: 20px; border-radius: 15px; margin-bottom: 20px;
            display: flex; gap: 15px; align-items: center; box-shadow: var(--shadow); flex-wrap: wrap;
        }
        .search-box { flex: 2; position: relative; min-width: 250px; }
        .search-box input {
            width: 100%; padding: 12px 45px 12px 15px; border: 2px solid #eee;
            border-radius: 10px; font-size: 1rem; outline: none; font-family: 'Tajawal'; transition: 0.3s;
        }
        .search-box i { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: #b2bec3; }

        .table-wrapper { background: white; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
        .scroll-area { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 1100px; }
        thead th { background: var(--navy); color: var(--gold); padding: 18px; font-size: 0.95rem; font-weight: 700; }
        tbody tr { transition: 0.2s; border-bottom: 1px solid #f1f2f6; }
        tbody tr:hover { background-color: #fffdf2; }
        td { padding: 15px; text-align: center; vertical-align: middle; font-size: 0.9rem; }

        /* تنبيهات الألوان */
        .expired { color: var(--danger); font-weight: bold; background: #fff5f5; padding: 5px 10px; border-radius: 8px; border: 1px solid #ffcccc; display: inline-block;}
        .near-expiry { color: var(--warning); font-weight: bold; background: #fffbe6; padding: 5px 10px; border-radius: 8px; border: 1px solid #ffe58f; display: inline-block;}
        .valid { color: var(--success); font-weight: bold; }

        .badge-nat { padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: bold; background: #f1f2f6; color: var(--navy); border: 1px solid #ddd; }
        .info-tag { font-size: 0.75rem; color: #666; display: block; margin-top: 4px; }
        
        .car-info-box { font-size: 0.75rem; color: #856404; background: #fff9db; padding: 6px; border-radius: 8px; margin-top: 5px; border: 1px solid #ffeeba; display: flex; align-items: center; justify-content: center; gap: 5px; }

        .btn-circle { width: 35px; height: 35px; border-radius: 8px; border: none; cursor: pointer; color: white; transition: 0.3s; display: inline-flex; align-items: center; justify-content: center; text-decoration: none;}
        .whatsapp-btn { background: #25d366; color: white; }
        
        .main-btn { padding: 10px 20px; border-radius: 12px; border: none; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; font-family: 'Tajawal'; transition: 0.3s; }

        /* Modal Customization */
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:3000; backdrop-filter: blur(5px); }
        .modal-content { background:white; width:90%; max-width:600px; margin:50px auto; padding:30px; border-radius:25px; position: relative; max-height: 85vh; overflow-y: auto; }
        
        .detail-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px dashed #eee; }
        .detail-label { font-weight: bold; color: var(--navy); }

        #toast { position: fixed; bottom: 20px; right: 20px; background: var(--navy); color: var(--gold); padding: 15px 25px; border-radius: 10px; display: none; z-index: 4000; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
    </style>
</head>
<body>

<header>
    <div style="display:flex; align-items:center; gap:15px;">
        <i class="fas fa-chart-line fa-2x"></i>
        <h2 style="margin:0">لوحة تحكم: <span id="mgrName" style="color:white">...</span></h2>
    </div>
    <div style="display:flex; gap:10px;">
        <button class="main-btn" style="background:#6c5ce7; color:white;" onclick="goToLicenses()">
            <i class="fas fa-file-contract"></i> السجلات الحكومية
        </button>
        <button class="main-btn" style="background:var(--gold); color:var(--navy)" onclick="copyLink(event)">
            <i class="fas fa-share-nodes"></i> رابط تسجيل الموظفين
        </button>
        <button class="main-btn" style="background:var(--danger); color:white" onclick="logout()">
            <i class="fas fa-power-off"></i> خروج
        </button>
    </div>
</header>

<div class="container">
    <div class="stats-bar">
        <div class="stat-card">
            <i class="fas fa-users stat-icon"></i>
            <span class="stat-val" id="totalCount">0</span>
            <span class="stat-label">إجمالي القوى العاملة</span>
        </div>
        <div class="stat-card" style="border-top-color:var(--danger)">
            <i class="fas fa-id-card-clip stat-icon"></i>
            <span class="stat-val" id="expiredCount" style="color:var(--danger)">0</span>
            <span class="stat-label">تنبيهات الإقامة</span>
        </div>
        <div class="stat-card" style="border-top-color:var(--warning)">
            <i class="fas fa-car-burst stat-icon"></i>
            <span class="stat-val" id="carAlertCount" style="color:var(--warning)">0</span>
            <span class="stat-label">مفوضي السيارات</span>
        </div>
        <div class="stat-card" style="border-top-color:var(--success)">
            <i class="fas fa-heart-pulse stat-icon"></i>
            <span class="stat-val" id="insuranceCount" style="color:var(--success)">0</span>
            <span class="stat-label">مؤمنين طبياً</span>
        </div>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="ابحث بالاسم، رقم الهوية، أو المدينة..." onkeyup="filterData()">
        </div>
        <select id="statusFilter" onchange="filterData()" style="padding: 12px; border-radius: 10px; border: 2px solid #eee; font-family: 'Tajawal'; outline:none;">
            <option value="all">جميع الموظفين</option>
            <option value="expired">الإقامات المنتهية فقط</option>
            <option value="valid">الإقامات السارية</option>
        </select>
        <button class="main-btn" style="background:var(--navy); color:white;" onclick="exportToExcel()">
            <i class="fas fa-file-excel"></i> تصدير البيانات
        </button>
    </div>

    <div class="table-wrapper">
        <div class="scroll-area">
            <table id="empTable">
                <thead>
                    <tr>
                        <th style="text-align:right">الموظف</th>
                        <th>الهوية / الإقامة</th>
                        <th>الجنسية والسكن</th>
                        <th>الجوال</th>
                        <th>انتهاء الهوية</th>
                        <th>التأمين والجواز</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="empTableBody">
                    <tr><td colspan="7">جاري المزامنة مع قاعدة البيانات...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="viewModal" class="modal">
    <div class="modal-content">
        <h3 style="margin-top:0; color:var(--navy); border-bottom: 2px solid var(--gold); padding-bottom:10px;">
            <i class="fas fa-address-card"></i> الملف الشخصي الكامل
        </h3>
        <div id="modalDetails">
            </div>
        <div style="margin-top:25px; display:flex; gap:10px;">
            <button class="main-btn" style="background:var(--navy); color:white; flex:1; justify-content:center" onclick="closeModal()">إغلاق النافذة</button>
        </div>
    </div>
</div>

<div id="toast">تمت العملية بنجاح!</div>

<script>
    let allEmployees = [];
    let currentScopeId = "";

    async function loadData() {
        const urlParams = new URLSearchParams(window.location.search);
        currentScopeId = urlParams.get('scope') || localStorage.getItem('scopeId');

        if (!currentScopeId) { window.location.href = '/manager/login'; return; }
        localStorage.setItem('scopeId', currentScopeId);

        try {
            // جلب اسم المنشأة
            const scopeRes = await fetch(`/manager/api/get-scope-info/${currentScopeId}`);
            if(scopeRes.ok) {
                const scopeData = await scopeRes.json();
                document.getElementById('mgrName').innerText = scopeData.name || "منشأة أبو حمزة";
            }

            // جلب الموظفين
            const res = await fetch(`/manager/api/get-employees/${currentScopeId}`);
            if (res.ok) {
                allEmployees = await res.json();
                filterData();
                updateStats();
            }
        } catch (e) {
            showToast("فشل في تحديث البيانات", true);
        }
    }

    function updateStats() {
        document.getElementById('totalCount').innerText = allEmployees.length;
        document.getElementById('expiredCount').innerText = allEmployees.filter(e => calculateDays(e.idExpiry) < 0).length;
        document.getElementById('insuranceCount').innerText = allEmployees.filter(e => e.hasHealthInsurance === true).length;
        document.getElementById('carAlertCount').innerText = allEmployees.filter(e => e.hasCarAuthorization === true).length;
    }

    function calculateDays(date) { 
        if(!date) return 999; 
        const diff = new Date(date) - new Date();
        return Math.ceil(diff / (1000 * 60 * 60 * 24)); 
    }

    function getExpiryStatus(date) {
        const days = calculateDays(date);
        if (days < 0) return { class: 'expired', text: 'منتهية' };
        if (days <= 30) return { class: 'near-expiry', text: `ينتهي خلال ${days} يوم` };
        return { class: 'valid', text: new Date(date).toLocaleDateString('ar-SA') };
    }

    function renderTable(data) {
        const body = document.getElementById('empTableBody');
        body.innerHTML = data.map(emp => {
            const idStatus = getExpiryStatus(emp.idExpiry);
            const whatsappMsg = `السلام عليكم أ/ ${emp.fullName}، نود إشعاركم بخصوص بياناتكم في المنصة.`;
            
            return `
                <tr>
                    <td style="text-align:right">
                        <strong>${emp.fullName}</strong>
                        <span class="info-tag">${emp.familyStatus || 'أعزب'}</span>
                    </td>
                    <td><code>${emp.idNumber || '---'}</code></td>
                    <td>
                        <span class="badge-nat">${emp.nationality || 'غير محدد'}</span>
                        <span class="info-tag"><i class="fas fa-location-dot"></i> ${emp.branch || 'غير محدد'}</span>
                    </td>
                    <td>
                        <a href="https://wa.me/${emp.phoneNumber}?text=${encodeURIComponent(whatsappMsg)}" target="_blank" class="btn-circle whatsapp-btn">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                        <small>${emp.phoneNumber || '---'}</small>
                    </td>
                    <td><span class="${idStatus.class}">${idStatus.text}</span></td>
                    <td>
                        <div style="font-size:0.8rem">
                            <i class="fas fa-passport"></i> ${emp.passportNumber ? 'ساري' : 'غير مسجل'}<br>
                            <i class="fas fa-shield-heart"></i> ${emp.hasHealthInsurance ? 'مؤمن' : 'لا يوجد'}
                        </div>
                    </td>
                    <td>
                        <div style="display:flex; gap:5px; justify-content:center">
                            <button class="btn-circle" style="background:var(--navy)" onclick="viewDetails('${emp._id}')"><i class="fas fa-eye"></i></button>
                            <button class="btn-circle" style="background:var(--danger)" onclick="deleteEmp('${emp._id}', '${emp.fullName}')"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>`;
        }).join('');
    }

    function viewDetails(id) {
        const emp = allEmployees.find(e => e._id === id);
        if(!emp) return;
        
        const content = `
            <div class="detail-row"><span class="detail-label">الاسم بالكامل:</span> <span>${emp.fullName}</span></div>
            <div class="detail-row"><span class="detail-label">رقم الهوية:</span> <span>${emp.idNumber}</span></div>
            <div class="detail-row"><span class="detail-label">تاريخ الانتهاء:</span> <span>${emp.idExpiry}</span></div>
            <div class="detail-row"><span class="detail-label">الكفيل الحالي:</span> <span>${emp.sponsorName || 'لا يوجد'}</span></div>
            <div class="detail-row"><span class="detail-label">رقم الجواز:</span> <span>${emp.passportNumber || '---'}</span></div>
            <div class="detail-row"><span class="detail-label">التأمين الصحي:</span> <span>${emp.hasHealthInsurance ? 'نعم' : 'لا'}</span></div>
            <div class="detail-row"><span class="detail-label">تفويض سيارة:</span> <span>${emp.hasCarAuthorization ? 'نعم (' + emp.carType + ')' : 'لا'}</span></div>
            <div class="detail-row"><span class="detail-label">العنوان:</span> <span>${emp.address || 'غير محدد'}</span></div>
            <div class="detail-row"><span class="detail-label">تاريخ نقل الكفالة:</span> <span>${emp.sponsorshipTransferDate || '---'}</span></div>
        `;
        document.getElementById('modalDetails').innerHTML = content;
        document.getElementById('viewModal').style.display = 'block';
    }

    function filterData() {
        const term = document.getElementById('searchInput').value.toLowerCase();
        const filter = document.getElementById('statusFilter').value;
        
        const filtered = allEmployees.filter(emp => {
            const matchSearch = emp.fullName.toLowerCase().includes(term) || emp.idNumber.includes(term);
            const days = calculateDays(emp.idExpiry);
            
            if (filter === 'expired') return matchSearch && days < 0;
            if (filter === 'valid') return matchSearch && days >= 0;
            return matchSearch;
        });
        renderTable(filtered);
    }

    function copyLink(e) {
        const link = `${window.location.origin}/employee/register?scope=${currentScopeId}`;
        navigator.clipboard.writeText(link);
        showToast("تم نسخ رابط تسجيل الموظفين");
    }

    function showToast(msg, isError = false) {
        const t = document.getElementById('toast');
        t.innerText = msg;
        t.style.background = isError ? "var(--danger)" : "var(--navy)";
        t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 3000);
    }

    function closeModal() { document.getElementById('viewModal').style.display = 'none'; }
    function logout() { localStorage.clear(); window.location.href = '/manager/login'; }
    function goToLicenses() { window.location.href = `/manager/licenses?scope=${currentScopeId}`; }

    window.onload = loadData;
</script>
</body>
</html>