<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | Golden Cloud</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --navy: #0b1d2a; --gold: #ffcc00; --white: #ffffff;
            --danger: #ff4757; --warning: #ffa502; --success: #2ed573;
            --gray: #7f8c8d; --whatsapp: #25D366; --bg: #f8f9fa;
        }
        
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; color: #2d3436; }
        
        header {
            background: var(--navy); color: var(--gold); padding: 15px 25px;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3); position: sticky; top: 0; z-index: 1000;
        }
        
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }

        .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 25px; }
        .stat-card {
            background: white; padding: 20px; border-radius: 15px; text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05); transition: 0.3s; border-top: 5px solid var(--navy);
        }
        .stat-card:hover { transform: translateY(-5px); }
        .stat-val { font-size: 1.8rem; font-weight: 700; display: block; color: var(--navy); }
        .stat-label { font-size: 1rem; color: #636e72; font-weight: 500; }

        .toolbar {
            background: white; padding: 20px; border-radius: 15px; margin-bottom: 20px;
            display: flex; gap: 15px; align-items: center; box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }
        .search-box { flex: 1; position: relative; }
        .search-box input {
            width: 100%; padding: 12px 45px 12px 15px; border: 2px solid #eee;
            border-radius: 10px; font-size: 1rem; transition: 0.3s; outline: none;
        }
        .search-box i { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: #b2bec3; }

        .table-wrapper { background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
        .scroll-area { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 1300px; }
        thead th { background: var(--navy); color: var(--gold); padding: 18px; font-size: 0.95rem; font-weight: 700; }
        tbody tr { transition: 0.2s; border-bottom: 1px solid #f1f2f6; }
        td { padding: 12px 15px; text-align: center; vertical-align: middle; font-size: 0.9rem; }

        .expired { color: var(--danger); font-weight: bold; }
        .near-expiry { color: var(--warning); font-weight: bold; }
        .valid { color: var(--success); }

        .badge-nat { padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: bold; background: #f1f2f6; color: var(--navy); border: 1px solid #ddd; }
        .gender-tag { padding: 4px 8px; border-radius: 6px; font-size: 0.8rem; font-weight: bold; }
        .male { background: #e3f2fd; color: #1976d2; }
        .female { background: #fce4ec; color: #c2185b; }
        
        .car-info { font-size: 0.75rem; color: #555; background: #fff9db; padding: 4px; border-radius: 5px; margin-top: 5px; border: 1px solid #ffe066; }

        .action-group { display: flex; gap: 8px; justify-content: center; }
        .btn-circle {
            width: 35px; height: 35px; border-radius: 8px; border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: 0.3s; font-size: 1rem; color: white;
        }
        .btn-ed { background: #3498db; }
        .btn-de { background: var(--danger); }

        .main-btn {
            padding: 10px 20px; border-radius: 12px; border: none; font-family: 'Tajawal';
            font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.3s;
        }

        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:3000; backdrop-filter: blur(5px); }
        .modal-content {
            background:white; width:95%; max-width:600px; margin:40px auto; padding:30px;
            border-radius:25px; position: relative;
        }
    </style>
</head>
<body>

<header>
    <div style="display:flex; align-items:center; gap:15px;">
        <i class="fas fa-user-shield fa-2x"></i>
        <h2 style="margin:0">إدارة نطاق: <span id="mgrName" style="color:white">جاري التحميل...</span></h2>
    </div>
    <div style="display:flex; gap:10px;">
        <button class="main-btn" style="background:#6c5ce7; color:white;" onclick="window.location.href='/manager/licenses?scope=' + currentScopeId">
            <i class="fas fa-file-contract"></i> السجلات والرخص
        </button>
        <button class="main-btn" style="background:var(--gold); color:var(--navy)" onclick="copyLink()">
            <i class="fas fa-link"></i> رابط التسجيل
        </button>
        <button class="main-btn" style="background:var(--danger); color:white" onclick="logout()">
            <i class="fas fa-sign-out-alt"></i> خروج
        </button>
    </div>
</header>

<div class="container">
    <div class="stats-bar">
        <div class="stat-card"> <span class="stat-val" id="totalCount">0</span> <span class="stat-label">إجمالي الموظفين</span> </div>
        <div class="stat-card" style="border-top-color:var(--danger)"> <span class="stat-val" id="expiredCount" style="color:var(--danger)">0</span> <span class="stat-label">إقامات منتهية</span> </div>
        <div class="stat-card" style="border-top-color:var(--success)"> <span class="stat-val" id="saudiCount" style="color:var(--success)">0</span> <span class="stat-label">مواطنون</span> </div>
        <div class="stat-card" style="border-top-color:var(--gray)"> <span class="stat-val" id="expatCount" style="color:var(--gray)">0</span> <span class="stat-label">مقيمون</span> </div>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="ابحث بالاسم، الرقم، أو الجنسية..." onkeyup="filterData()">
        </div>
        <select id="statusFilter" onchange="filterData()" style="padding: 12px; border-radius: 10px; border: 2px solid #eee; font-family: 'Tajawal'; outline:none;">
            <option value="all">كل الجنسيات</option>
            <option value="السعودية">سعودي</option>
            <option value="غير سعودي">مقيم (أجنبي)</option>
        </select>
    </div>

    <div class="table-wrapper">
        <div class="scroll-area">
            <table id="empTable">
                <thead>
                    <tr>
                        <th>الموظف / الهوية</th>
                        <th>الجنسية / الجنس</th>
                        <th>الجوال</th>
                        <th>انتهاء الهوية</th>
                        <th>انتهاء الجواز</th>
                        <th>التأمين / السيارة</th>
                        <th>العمليات</th>
                    </tr>
                </thead>
                <tbody id="empTableBody">
                    <tr><td colspan="7">جاري جلب البيانات...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="editModal" class="modal">
    <div class="modal-content">
        <h3><i class="fas fa-user-edit"></i> تعديل بيانات الموظف</h3>
        <input type="hidden" id="edit_empId">
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; margin-bottom:15px;">
            <div style="grid-column: span 2;">
                <label>الاسم الكامل</label>
                <input type="text" id="edit_fullName" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd;">
            </div>
            <div>
                <label>رقم الهوية</label>
                <input type="text" id="edit_idNumber" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd;">
            </div>
            <div>
                <label>رقم الجوال</label>
                <input type="text" id="edit_phoneNumber" style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd;">
            </div>
        </div>
        <button class="main-btn" style="background:var(--success); color:white; width:100%; justify-content:center" onclick="saveChanges()">حفظ التعديلات</button>
        <button onclick="closeModal()" style="width:100%; background:none; border:none; margin-top:10px; cursor:pointer; color:var(--gray)">إلغاء</button>
    </div>
</div>

<script>
    let allEmployees = [];
    let currentScopeId = "";

    async function loadData() {
        const urlParams = new URLSearchParams(window.location.search);
        const scopeFromURL = urlParams.get('scope');
        const scopeFromStorage = localStorage.getItem('scopeId');
        
        currentScopeId = scopeFromURL || scopeFromStorage;

        if (!currentScopeId || currentScopeId === "null") { 
            window.location.href = '/manager/login'; 
            return; 
        }

        if (scopeFromURL) localStorage.setItem('scopeId', scopeFromURL);

        try {
            const scopeRes = await fetch(`/manager/api/get-scope-info/${currentScopeId}`);
            if(scopeRes.ok) {
                const scopeData = await scopeRes.json();
                document.getElementById('mgrName').innerText = scopeData.name || "نطاق غير معروف";
            }

            const res = await fetch(`/manager/api/get-employees/${currentScopeId}`);
            allEmployees = await res.json();
            filterData();
            updateStats();
        } catch (e) { 
            document.getElementById('empTableBody').innerHTML = '<tr><td colspan="7">خطأ في جلب البيانات</td></tr>';
        }
    }

    function calculateDays(date) { 
        if(!date) return 0; 
        const diff = new Date(date) - new Date();
        return Math.ceil(diff / (1000 * 60 * 60 * 24)); 
    }

    function formatDate(date) { 
        if(!date) return "---";
        return new Date(date).toLocaleDateString('ar-SA'); 
    }

    function getExpiryClass(date) {
        if (!date) return "";
        const days = calculateDays(date);
        if (days < 0) return "expired";
        if (days <= 30) return "near-expiry";
        return "valid";
    }

    function renderTable(data) {
        const body = document.getElementById('empTableBody');
        if(!data || data.length === 0) { body.innerHTML = '<tr><td colspan="7">لا توجد سجلات</td></tr>'; return; }
        
        body.innerHTML = data.map(emp => {
            const genderClass = emp.gender === 'أنثى' ? 'female' : 'male';
            
            // معالجة التأمين
            const insuranceText = (emp.hasHealthInsurance === 'true' || emp.hasHealthInsurance === true)
                                  ? `<span class="${getExpiryClass(emp.insuranceExpiry)}">تأمين: ${formatDate(emp.insuranceExpiry)}</span>` 
                                  : '<span style="color:#ccc">بدون تأمين</span>';

            // معالجة السيارة
            const carInfo = emp.hasCarAuthorization 
                            ? `<div class="car-info"><i class="fas fa-car"></i> ${emp.carType || 'سيارة'} - ${emp.carPlate || ''}</div>`
                            : '';

            return `
                <tr>
                    <td><strong>${emp.fullName}</strong><br><small>${emp.idNumber || '---'}</small></td>
                    <td>
                        <span class="badge-nat">${emp.nationality || 'غير محدد'}</span><br>
                        <span class="gender-tag ${genderClass}">${emp.gender || 'ذكر'}</span>
                    </td>
                    <td>${emp.phoneNumber || '---'}</td>
                    <td class="${getExpiryClass(emp.idExpiry)}">
                        ${formatDate(emp.idExpiry)}<br>
                        <small>(${calculateDays(emp.idExpiry)} يوم)</small>
                    </td>
                    <td class="${getExpiryClass(emp.passportExpiry)}">
                        ${emp.passportNumber ? formatDate(emp.passportExpiry) : '---'}
                    </td>
                    <td>
                        ${insuranceText}
                        ${carInfo}
                    </td>
                    <td>
                        <div class="action-group">
                            <button class="btn-circle btn-ed" onclick="editEmp('${emp._id}')"><i class="fas fa-edit"></i></button>
                            <button class="btn-circle btn-de" onclick="deleteEmp('${emp._id}', '${emp.fullName}')"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>`;
        }).join('');
    }

    function filterData() {
        const term = document.getElementById('searchInput').value.toLowerCase();
        const filter = document.getElementById('statusFilter').value;
        
        const filtered = allEmployees.filter(emp => {
            const matchSearch = emp.fullName?.toLowerCase().includes(term) || 
                                emp.idNumber?.includes(term) || 
                                emp.nationality?.includes(term);
            
            let matchType = true;
            if (filter === 'السعودية') matchType = emp.nationality === 'السعودية';
            if (filter === 'غير سعودي') matchType = emp.nationality !== 'السعودية';

            return matchSearch && matchType;
        });
        renderTable(filtered);
    }

    function updateStats() {
        document.getElementById('totalCount').innerText = allEmployees.length;
        document.getElementById('expiredCount').innerText = allEmployees.filter(e => calculateDays(e.idExpiry) < 0).length;
        document.getElementById('saudiCount').innerText = allEmployees.filter(e => e.nationality === 'السعودية').length;
        document.getElementById('expatCount').innerText = allEmployees.filter(e => e.nationality !== 'السعودية').length;
    }

    function editEmp(id) {
        const emp = allEmployees.find(e => e._id === id);
        if(!emp) return;
        document.getElementById('edit_empId').value = emp._id;
        document.getElementById('edit_fullName').value = emp.fullName;
        document.getElementById('edit_phoneNumber').value = emp.phoneNumber || '';
        document.getElementById('edit_idNumber').value = emp.idNumber || '';
        document.getElementById('editModal').style.display = 'block';
    }

    async function saveChanges() {
        const id = document.getElementById('edit_empId').value;
        const data = {
            fullName: document.getElementById('edit_fullName').value,
            idNumber: document.getElementById('edit_idNumber').value,
            phoneNumber: document.getElementById('edit_phoneNumber').value
        };

        try {
            const res = await fetch(`/manager/api/update-employee/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            if(res.ok) {
                alert('تم التحديث بنجاح');
                closeModal();
                loadData();
            }
        } catch (e) { alert('خطأ في التحديث'); }
    }

    async function deleteEmp(id, name) {
        if(!confirm(`هل أنت متأكد من حذف الموظف: ${name}؟`)) return;
        try {
            const res = await fetch(`/manager/api/delete-employee/${id}`, { method: 'DELETE' });
            if(res.ok) { loadData(); }
        } catch (e) { alert('خطأ في الحذف'); }
    }

    function closeModal() { document.getElementById('editModal').style.display = 'none'; }
    function logout() { localStorage.clear(); window.location.href = '/manager/login'; }

    function copyLink() {
        const link = window.location.origin + '/employee/register/' + currentScopeId;
        navigator.clipboard.writeText(link).then(() => alert('✅ تم نسخ رابط التسجيل'));
    }

    loadData();
</script>
</body>
</html>