<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لوحة التحكم العليا | أبو حمزة</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --navy: #0d2d4d; --gold: #ffcc00; --teal: #1abc9c; --bg: #f4f7f6; --red: #e74c3c; }
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; display: flex; }
        .sidebar { width: 260px; background: var(--navy); color: white; height: 100vh; position: fixed; padding: 20px; }
        .main-content { margin-right: 260px; flex: 1; padding: 30px; }
        .sidebar-nav { list-style: none; padding: 0; }
        .sidebar-nav a { color: white; text-decoration: none; display: block; padding: 12px; cursor: pointer; border-radius: 8px; margin-bottom: 10px; }
        .sidebar-nav a:hover, .sidebar-nav a.active { background: var(--teal); }
        .btn-logout { background: var(--red) !important; text-align: center; font-weight: bold; margin-top: 50px; }
        .card { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 12px; border-bottom: 1px solid #eee; text-align: right; }
    </style>
</head>
<body>

    <script>
        // 🛡️ الحارس الأمني المطور لمنع الثقل (أبو حمزة)
        (function checkAuth() {
            const role = localStorage.getItem('role');
            if (role !== 'super-admin') {
                const pass = prompt("أدخل كلمة مرور السوبر أدمن للوصول:");
                if (pass === 'hDB3xqff@') {
                    localStorage.setItem('role', 'super-admin');
                    localStorage.setItem('token', 'true');
                } else {
                    alert("عذراً، كلمة المرور خاطئة!");
                    window.location.replace('/'); 
                }
            }
        })();

        function logoutMaster() {
            if(confirm("أبو حمزة، هل أنت متأكد من تسجيل الخروج؟")) {
                localStorage.clear();
                window.location.replace('/');
            }
        }
    </script>

    <div class="sidebar">
        <h2 style="color: var(--gold); text-align: center;">السحابة الذهبية</h2>
        <ul class="sidebar-nav">
            <li><a onclick="showSection('add-scope-section', this)" class="active">✨ إضافة نطاق جديد</a></li>
            <li><a onclick="showSection('scopes-section', this)">📦 إدارة النطاقات</a></li>
            <li><a onclick="showSection('managers-section', this)">👥 حسابات المدراء</a></li>
            <li><a onclick="logoutMaster()" class="btn-logout">تسجيل الخروج 🚪</a></li>
        </ul>
    </div>

    <div class="main-content">
        <h1>لوحة التحكم العليا | أبو حمزة</h1>
        <div id="add-scope-section" class="page-section">
            <div class="card">
                <h3>🆕 تأسيس نطاق جديد</h3>
                </div>
        </div>
        </div>

    <script>
        function showSection(id, el) {
            document.querySelectorAll('.page-section').forEach(s => s.style.display = 'none');
            document.getElementById(id).style.display = 'block';
            document.querySelectorAll('.sidebar-nav a').forEach(a => a.classList.remove('active'));
            el.classList.add('active');
            if(id === 'scopes-section') loadScopes();
            if(id === 'managers-section') loadManagers();
        }

        async function loadManagers() {
            try {
                // استدعاء المسار الذي أصلحناه في السيرفر
                const res = await fetch('/admin/get-all-managers');
                const data = await res.json();
                // كود عرض الجدول هنا...
            } catch (e) { console.error("Error:", e); }
        }
    </script>
</body>
</html>