<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم العليا | منصة الكوارتز</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --navy: #0d2d4d; --gold: #ffcc00; --teal: #1abc9c; --bg: #f4f7f6; --red: #e74c3c; }
        * { box-sizing: border-box; }
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; display: flex; overflow-x: hidden; }

        /* القائمة الجانبية المصلحة */
        .sidebar { 
            width: 280px; background: var(--navy); color: white; height: 100vh; 
            position: fixed; right: 0; top: 0; padding: 20px; z-index: 1000;
        }
        .sidebar h2 { text-align: center; color: var(--gold); border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 20px; }

        /* المحتوى الرئيسي */
        .main-content { margin-right: 280px; width: calc(100% - 280px); padding: 40px; min-height: 100vh; }
        
        .sidebar-nav { list-style: none; padding: 0; margin-top: 30px; }
        .sidebar-nav a { 
            color: white; text-decoration: none; display: block; padding: 15px; 
            border-radius: 10px; cursor: pointer; transition: 0.3s; margin-bottom: 10px;
            background: rgba(255,255,255,0.05);
        }
        .sidebar-nav a:hover, .sidebar-nav a.active { background: var(--teal); }
        .btn-logout { background: var(--red) !important; color: white !important; font-weight: bold; margin-top: 50px; text-align: center; }

        /* البطاقات والجداول */
        .card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); margin-bottom: 30px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; text-align: right; }
        th, td { padding: 15px; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; color: var(--navy); }
        
        /* المدخلات */
        .form-group { margin-bottom: 20px; }
        input, select { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Tajawal'; font-size: 16px; }
        .btn-action { background: var(--navy); color: var(--gold); border: none; padding: 15px; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; font-size: 18px; }
        .status-active { color: #27ae60; font-weight: bold; }
        .status-expired { color: var(--red); font-weight: bold; }
        .btn-del { background: var(--red); color: white; border: none; padding: 5px 12px; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>

    <div class="sidebar">
        <h2>الكوارتز السحابي</h2>
        <ul class="sidebar-nav">
            <li><a onclick="showSection('add-scope-section', this)" class="active">✨ إضافة نطاق جديد</a></li>
            <li><a onclick="showSection('scopes-section', this)">📦 إدارة النطاقات</a></li>
            <li><a onclick="showSection('managers-section', this)">👥 حسابات المدراء</a></li>
            <li><a onclick="logoutMaster()" class="btn-logout">تسجيل الخروج 🚪</a></li>
        </ul>
    </div>

    <div class="main-content">
        <h1>لوحة التحكم العليا | أبو حمزة</h1>
        
        <div id="add-scope-section" class="page-section">
            <div class="card">
                <h3>🆕 تأسيس نطاق شركة جديد</h3>
                <div class="form-group">
                    <input type="text" id="scopeName" placeholder="اسم الشركة / النطاق الجديد">
                </div>
                <div class="form-group">
                    <select id="scopeMonths">
                        <option value="1">اشتراك شهر واحد</option>
                        <option value="6">اشتراك 6 أشهر</option>
                        <option value="12">اشتراك سنة كاملة</option>
                    </select>
                </div>
                <button class="btn-action" onclick="createScope()">تفعيل النطاق فوراً</button>
            </div>
        </div>

        <div id="scopes-section" class="page-section" style="display:none;">
            <div class="card">
                <h3>📦 النطاقات المسجلة والاشتراكات</h3>
                <table id="scopesTable">
                    <thead>
                        <tr><th>الشركة</th><th>المعرف</th><th>الانتهاء</th><th>الحالة</th><th>حذف</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <div id="managers-section" class="page-section" style="display:none;">
            <div class="card">
                <h3>👤 إضافة مدير لنطاق نشط</h3>
                <input type="text" id="mgrName" placeholder="اسم المدير" style="margin-bottom:10px;">
                <input type="email" id="mgrEmail" placeholder="البريد الإلكتروني" style="margin-bottom:10px;">
                <input type="password" id="mgrPass" placeholder="كلمة المرور" style="margin-bottom:10px;">
                <select id="mgrScopeSelect" style="margin-bottom:20px;"></select>
                <button class="btn-action" onclick="createManager()">حفظ وصرف صلاحية</button>
            </div>
            <div class="card">
                <h3>📋 كشف المدراء</h3>
                <table id="managersTable">
                    <thead>
                        <tr><th>المدير</th><th>البريد</th><th>النطاق</th><th>إجراء</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // --- [ الدوال البرمجية ] ---
        async function createScope() {
            const name = document.getElementById('scopeName').value;
            const months = document.getElementById('scopeMonths').value;
            if(!name) return alert("يرجى كتابة اسم الشركة");
            
            const res = await fetch('/admin/add-scope', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ name, months })
            });
            if(res.ok) { alert("تم إنشاء النطاق"); location.reload(); }
        }

        async function loadScopes() {
            const res = await fetch('/admin/get-all-scopes');
            const data = await res.json();
            const tbody = document.querySelector('#scopesTable tbody');
            const select = document.getElementById('mgrScopeSelect');
            tbody.innerHTML = '';
            select.innerHTML = '<option value="">اختر النطاق للربط</option>';

            data.forEach(s => {
                const isExpired = new Date(s.expiry) < new Date();
                tbody.innerHTML += `
                    <tr>
                        <td>${s.name}</td>
                        <td>${s.uniqueId}</td>
                        <td>${new Date(s.expiry).toLocaleDateString('ar-EG')}</td>
                        <td class="${isExpired ? 'status-expired' : 'status-active'}">${isExpired ? 'معلق' : 'نشط'}</td>
                        <td><button class="btn-del" onclick="deleteItem('${s._id}', 'scope')">حذف</button></td>
                    </tr>
                `;
                select.innerHTML += `<option value="${s.uniqueId}">${s.name}</option>`;
            });
        }

        async function createManager() {
            const payload = {
                name: document.getElementById('mgrName').value,
                email: document.getElementById('mgrEmail').value,
                password: document.getElementById('mgrPass').value,
                scopeId: document.getElementById('mgrScopeSelect').value
            };
            const res = await fetch('/admin/add-manager', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(payload)
            });
            if(res.ok) { alert("تمت إضافة المدير"); showSection('managers-section', document.querySelector('a[onclick*="managers-section"]')); }
        }

        async function loadManagers() {
            const res = await fetch('/admin/get-all-managers');
            const data = await res.json();
            const tbody = document.querySelector('#managersTable tbody');
            tbody.innerHTML = data.map(m => `
                <tr>
                    <td>${m.name}</td>
                    <td>${m.email}</td>
                    <td>${m.scopeId}</td>
                    <td><button class="btn-del" onclick="deleteItem('${m._id}', 'manager')">سحب صلاحية</button></td>
                </tr>
            `).join('');
        }

        async function deleteItem(id, type) {
            const pass = prompt("أدخل كلمة مرور الماستر للحذف:");
            if(pass !== 'hDB3xqff@') return alert("خطأ!");
            const res = await fetch('/admin/verify-and-delete', {
                method: 'DELETE',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ id, type, password: pass })
            });
            if(res.ok) location.reload();
        }

        function showSection(id, el) {
            document.querySelectorAll('.page-section').forEach(s => s.style.display = 'none');
            document.getElementById(id).style.display = 'block';
            document.querySelectorAll('.sidebar-nav a').forEach(a => a.classList.remove('active'));
            el.classList.add('active');
            if(id === 'scopes-section') loadScopes();
            if(id === 'managers-section') { loadScopes(); loadManagers(); }
        }

        function logoutMaster() {
            localStorage.clear();
            window.location.replace('/');
        }
    </script>
</body>
</html>