<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تحديث بيانات الموظفين | منصة أبو حمزة</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --navy: #0b1d2a; --gold: #ffcc00; --bg: #f4f7f6; --success: #27ae60; --gray: #666; --red: #e74c3c; }
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); display: flex; justify-content: center; padding: 20px; margin: 0; }
        
        .form-card { 
            background: white; width: 100%; max-width: 650px; padding: 35px; 
            border-radius: 25px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); 
            border-top: 10px solid var(--navy); 
        }

        .progress-container { width: 100%; background: #eee; height: 8px; border-radius: 10px; margin-bottom: 25px; overflow: hidden; }
        .progress-bar { width: 20%; height: 100%; background: var(--gold); transition: 0.5s ease; }
        
        .motivation { color: var(--success); font-weight: bold; margin-bottom: 20px; text-align: center; min-height: 24px; font-size: 18px; }
        
        .step { display: none; }
        .step.active { display: block; animation: fadeIn 0.5s forwards; }
        
        label { display: block; margin-bottom: 8px; font-size: 0.95rem; color: var(--navy); font-weight: 700; margin-top: 15px; }
        input, select { width: 100%; padding: 12px; border: 2px solid #eee; border-radius: 10px; font-family: 'Tajawal'; font-size: 15px; box-sizing: border-box; transition: 0.3s; }
        input:focus, select:focus { border-color: var(--gold); outline: none; background: #fffcf0; }
        
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .btn-group { display: flex; gap: 10px; margin-top: 30px; }
        button { flex: 1; padding: 15px; border-radius: 12px; border: none; font-weight: bold; cursor: pointer; font-family: 'Tajawal'; font-size: 16px; transition: 0.3s; }
        .btn-next { background: var(--navy); color: var(--gold); }
        .btn-prev { background: #eee; color: #333; }
        
        .hidden-fields { display: none; background: #f9f9f9; padding: 15px; border-radius: 10px; border: 1px dashed #ddd; margin-top: 10px; }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        #success-container { display: none; text-align: center; padding: 20px; }
        .success-icon { font-size: 60px; color: var(--success); }
    </style>
</head>
<body>

<div class="form-card">
    <div id="form-content">
        <div class="progress-container"><div id="pBar" class="progress-bar"></div></div>
        <div id="motivationMsg" class="motivation">مرحباً بك! لنحدث بياناتك..</div>

        <form id="smartForm">
            <input type="hidden" name="scopeId" value="<%= scopeId %>">

            <div class="step active" data-step="1">
                <label>الاسم الكامل</label>
                <input type="text" name="fullName" required>
                
                <div class="grid-2">
                    <div>
                        <label>رقم الجوال</label>
                        <input type="tel" name="phoneNumber" placeholder="05xxxxxxxx" required>
                    </div>
                    <div>
                        <label>مدينة العمل / الفرع</label>
                        <input type="text" name="branch" placeholder="مثال: الرياض">
                    </div>
                </div>

                <label>عنوان السكن بالتفصيل</label>
                <input type="text" name="address">

                <div class="btn-group">
                    <button type="button" class="btn-next" onclick="nextStep(1, 'ممتاز، ننتقل لبيانات الهوية')">التالي ⮕</button>
                </div>
            </div>

            <div class="step" data-step="2">
                <label>رقم الهوية / الإقامة</label>
                <input type="text" name="idNumber" required maxlength="10">
                
                <label>تاريخ انتهاء الهوية</label>
                <input type="date" name="idExpiry" required>

                <label>اسم المنشأة الكفيلة الحالية</label>
                <input type="text" name="sponsorName" placeholder="كما تظهر في أبشر/مقيم">

                <div class="btn-group">
                    <button type="button" class="btn-prev" onclick="prevStep(2)">السابق</button>
                    <button type="button" class="btn-next" onclick="nextStep(2, 'رائع، الآن بيانات الجواز والتأمين')">التالي ⮕</button>
                </div>
            </div>

            <div class="step" data-step="3">
                <div class="grid-2">
                    <div>
                        <label>رقم الجواز</label>
                        <input type="text" name="passportNumber">
                    </div>
                    <div>
                        <label>انتهاء الجواز</label>
                        <input type="date" name="passportExpiry">
                    </div>
                </div>

                <label>هل لديك تأمين صحي؟</label>
                <select name="hasHealthInsurance" onchange="toggleBox(this, 'insuranceBox')">
                    <option value="false">لا يوجد</option>
                    <option value="true">نعم، يوجد</option>
                </select>

                <div id="insuranceBox" class="hidden-fields">
                    <label>تاريخ انتهاء التأمين</label>
                    <input type="date" name="insuranceExpiry">
                    <label>الحالة الصحية (إن وجد ملاحظات)</label>
                    <input type="text" name="healthStatus" placeholder="مثال: سليم">
                </div>

                <div class="btn-group">
                    <button type="button" class="btn-prev" onclick="prevStep(3)">السابق</button>
                    <button type="button" class="btn-next" onclick="nextStep(3, 'ماذا عن قيادة السيارة؟')">التالي ⮕</button>
                </div>
            </div>

            <div class="step" data-step="4">
                <div class="grid-2">
                    <div>
                        <label>هل لديك رخصة قيادة؟</label>
                        <select name="hasDrivingLicense">
                            <option value="false">لا</option>
                            <option value="true">نعم</option>
                        </select>
                    </div>
                    <div>
                        <label>هل لديك تفويض سيارة؟</label>
                        <select name="hasCarAuthorization">
                            <option value="false">لا</option>
                            <option value="true">نعم</option>
                        </select>
                    </div>
                </div>

                <div class="grid-2">
                    <div>
                        <label>نوع السيارة</label>
                        <input type="text" name="carType">
                    </div>
                    <div>
                        <label>رقم اللوحة</label>
                        <input type="text" name="carPlate">
                    </div>
                </div>

                <div class="btn-group">
                    <button type="button" class="btn-prev" onclick="prevStep(4)">السابق</button>
                    <button type="button" class="btn-next" onclick="nextStep(4, 'الخطوة الأخيرة: الوضع الاجتماعي')">التالي ⮕</button>
                </div>
            </div>

            <div class="step" data-step="5">
                <label>هل العائلة موجودة في السعودية؟</label>
                <select name="hasFamilyInKSA">
                    <option value="false">لا</option>
                    <option value="true">نعم</option>
                </select>

                <label>الوضع الاجتماعي (أعزب/متأهل)</label>
                <input type="text" name="familyStatus" placeholder="مثال: متزوج وعائل">

                <label>تاريخ نقل الكفالة (إن وجد)</label>
                <input type="date" name="sponsorshipTransferDate">

                <div class="btn-group">
                    <button type="button" class="btn-prev" onclick="prevStep(5)">السابق</button>
                    <button type="submit" id="submitBtn" class="btn-next" style="background:var(--success); color:white;">اعتماد وحفظ البيانات 🚀</button>
                </div>
            </div>
        </form>
    </div>

    <div id="success-container">
        <div class="success-icon">✓</div>
        <h2>شكراً لك يا بطل!</h2>
        <p>تم استلام وتحديث بياناتك في نظام أبو حمزة بنجاح.</p>
        <button class="btn-next" onclick="window.location.reload()">تسجيل جديد</button>
    </div>
</div>

<script>
    let current = 1;
    const total = 5;

    function nextStep(step, msg) {
        const currentStepEl = document.querySelector(`[data-step="${step}"]`);
        const inputs = currentStepEl.querySelectorAll('input[required]');
        
        for (let input of inputs) {
            if (!input.value) {
                input.style.borderColor = 'red';
                return;
            }
            input.style.borderColor = '#eee';
        }

        currentStepEl.classList.remove('active');
        document.querySelector(`[data-step="${step+1}"]`).classList.add('active');
        document.getElementById('motivationMsg').innerText = msg;
        current++;
        updateProgress();
    }

    function prevStep(step) {
        document.querySelector(`[data-step="${step}"]`).classList.remove('active');
        document.querySelector(`[data-step="${step-1}"]`).classList.add('active');
        current--;
        updateProgress();
    }

    function updateProgress() {
        const progress = (current / total) * 100;
        document.getElementById('pBar').style.width = progress + '%';
    }

    function toggleBox(select, boxId) {
        document.getElementById(boxId).style.display = select.value === 'true' ? 'block' : 'none';
    }

    document.getElementById('smartForm').onsubmit = async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerText = "جاري الحفظ...";

        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);
        
        // تحويل القيم المنطقية لتناسب الـ Schema
        const booleans = ['hasHealthInsurance', 'hasDrivingLicense', 'hasCarAuthorization', 'hasFamilyInKSA'];
        booleans.forEach(key => { data[key] = (data[key] === 'true'); });

        try {
            const res = await fetch('/employee/api/register', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            });
            if(res.ok) {
                document.getElementById('form-content').style.display = 'none';
                document.getElementById('success-container').style.display = 'block';
            } else {
                alert('حدث خطأ في الحفظ، يرجى المحاولة لاحقاً');
                btn.disabled = false;
            }
        } catch (err) {
            alert('فشل الاتصال بالسيرفر');
            btn.disabled = false;
        }
    };
</script>
</body>
</html>