<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | Golden Cloud Server</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        :root {
            --navy: #0b1d2a;
            --gold: #ffcc00;
            --white: #ffffff;
            --danger: #ff4757;
            --warning: #ffa502;
            --success: #2ed573;
            --info: #3498db;
            --gray-light: #f8f9fa;
            --gray-dark: #2d3436;
            --shadow-sm: 0 2px 10px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 40px rgba(0,0,0,0.15);
        }

        * { box-sizing: border-box; transition: all 0.2s ease; }
        body { 
            font-family: 'Tajawal', sans-serif; 
            background-color: #f0f2f5; 
            margin: 0; 
            color: var(--gray-dark);
            line-height: 1.6;
        }

        /* Header Styling */
        header {
            background: linear-gradient(135deg, var(--navy) 0%, #162e3e 100%);
            color: var(--gold);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 25px rgba(0,0,0,0.3);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo-section { display: flex; align-items: center; gap: 20px; }
        .logo-section i { font-size: 2.5rem; text-shadow: 0 0 15px rgba(255,204,0,0.4); }
        .logo-section h2 { margin: 0; font-weight: 800; letter-spacing: 1px; }
        .scope-badge { 
            background: rgba(255,255,255,0.1); 
            padding: 5px 15px; 
            border-radius: 50px; 
            color: #fff; 
            font-weight: 700; 
            font-size: 0.95rem;
            border: 1px solid var(--gold);
        }

        /* Stats Section */
        .container { max-width: 1600px; margin: 0 auto; padding: 30px; }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--white);
            padding: 25px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
            box-shadow: var(--shadow-sm);
            border-right: 6px solid var(--navy);
        }

        .stat-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
        .stat-icon {
            width: 60px; height: 60px;
            border-radius: 15px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem;
        }

        .stat-info h3 { margin: 0; font-size: 0.95rem; color: #7f8c8d; }
        .stat-info .value { font-size: 2rem; font-weight: 800; color: var(--navy); }

        /* Toolbar */
        .toolbar {
            background: var(--white);
            padding: 25px;
            border-radius: 20px;
            margin-bottom: 30px;
            display: flex;
            gap: 15px;
            align-items: center;
            box-shadow: var(--shadow-sm);
            flex-wrap: wrap;
        }

        .search-wrapper { flex: 1; position: relative; min-width: 300px; }
        .search-wrapper input {
            width: 100%;
            padding: 15px 50px 15px 20px;
            border: 2px solid #eee;
            border-radius: 15px;
            font-size: 1rem;
            font-family: inherit;
        }
        .search-wrapper i { position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: var(--navy); }

        /* Buttons */
        .btn {
            padding: 14px 22px;
            border-radius: 12px;
            border: none;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-family: inherit;
            text-decoration: none;
            font-size: 0.9rem;
        }

        .btn-excel { background: #1d7a46; color: white; }
        .btn-link { background: var(--gold); color: var(--navy); }
        .btn-license { background: #4b7bec; color: white; } /* اللون الجديد لزر السجلات */
        .btn-danger { background: var(--danger); color: white; }

        /* Table */
        .table-card {
            background: var(--white);
            border-radius: 25px;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        table { width: 100%; border-collapse: collapse; }
        thead th {
            background: var(--navy);
            color: var(--gold);
            padding: 20px;
            text-align: center;
        }

        td { padding: 18px; text-align: center; border-bottom: 1px solid #f0f0f0; }
        .emp-name { font-weight: 700; color: var(--navy); display: block; }

        /* Modal */
        .modal { 
            display:none; position:fixed; top:0; left:0; width:100%; height:100%; 
            background:rgba(11, 29, 42, 0.9); z-index:2000; backdrop-filter: blur(8px); 
        }
        .modal-content {
            background: #fff; width: 95%; max-width: 1100px; margin: 3vh auto;
            border-radius: 25px; position: relative; max-height: 90vh; overflow-y: auto;
        }
        .modal-header { padding: 25px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }
        
        .data-matrix {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px; padding: 25px;
        }
        .matrix-box { padding: 20px; border-radius: 15px; border: 1px solid #eee; }
        .box-blue { border-top: 5px solid var(--info); background: #f0f7ff; }
        .box-gold { border-top: 5px solid var(--gold); background: #fffdf0; }
        .box-green { border-top: 5px solid var(--success); background: #f0fff4; }

        .matrix-row { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem; }
        .matrix-label { color: #7f8c8d; font-weight: 500; }
        .matrix-value { color: var(--navy); font-weight: 700; }

        #toast {
            position: fixed; bottom: 30px; right: 30px;
            padding: 15px 30px; border-radius: 12px;
            display: none; z-index: 9999; color: white;
        }
    </style>
</head>
<body>

<header>
    <div class="logo-section">
        <i class="fas fa-cloud-meatball"></i>
        <div>
            <h2>Golden Cloud Server</h2>
            <div id="scopeNameDisplay" class="scope-badge">جاري التحميل...</div>
        </div>
    </div>
    <div style="display: flex; gap: 12px;">
        <a id="licenseBtn" class="btn btn-license">
            <i class="fas fa-file-contract"></i> السجلات والحكومية
        </a>
        <button class="btn btn-link" onclick="copyRegLink()">
            <i class="fas fa-user-plus"></i> رابط التسجيل
        </button>
        <button class="btn btn-danger" onclick="logout()">
            <i class="fas fa-power-off"></i> خروج
        </button>
    </div>
</header>

<div class="container">
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background: #e1f5fe; color: var(--info);"><i class="fas fa-users"></i></div>
            <div class="stat-info"><h3>إجمالي الكادر</h3><div class="value" id="count-total">0</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #fff9db; color: var(--warning);"><i class="fas fa-car"></i></div>
            <div class="stat-info"><h3>سيارات العهدة</h3><div class="value" id="count-cars">0</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #ffe3e6; color: var(--danger);"><i class="fas fa-id-card"></i></div>
            <div class="stat-info"><h3>هويات منتهية</h3><div class="value" id="count-expired">0</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #e8f5e9; color: var(--success);"><i class="fas fa-shield-heart"></i></div>
            <div class="stat-info"><h3>التغطية الطبية</h3><div class="value" id="count-medical">0</div></div>
        </div>
    </div>

    <div class="toolbar">
        <div class="search-wrapper">
            <i class="fas fa-search"></i>
            <input type="text" id="mainSearch" placeholder="ابحث بالاسم، الهوية، أو الجوال..." onkeyup="handleSearch()">
        </div>
        <button class="btn btn-excel" onclick="exportToExcel()">
            <i class="fas fa-file-excel"></i> تصدير (Excel)
        </button>
        <button class="btn" style="background: var(--navy); color: white;" onclick="loadEmployeeData()">
            <i class="fas fa-sync-alt"></i> تحديث
        </button>
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>الموظف</th>
                    <th>رقم الهوية</th>
                    <th>الجنسية</th>
                    <th>الجوال</th>
                    <th>انتهاء الهوية</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody id="employeeTable">
                <tr><td colspan="7">جاري سحب البيانات...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div id="empModal" class="modal" onclick="if(event.target==this) closeModal()">
    <div class="modal-content">
        <div class="modal-header">
            <h2 style="margin:0;"><i class="fas fa-id-badge"></i> الملف الرقمي للموظف</h2>
            <button onclick="closeModal()" style="border:none; background:none; font-size:2rem; cursor:pointer;">&times;</button>
        </div>
        <div id="matrixContent" class="data-matrix"></div>
    </div>
</div>

<div id="toast"></div>

<script>
    let rawData = [];
    const urlParams = new URLSearchParams(window.location.search);
    const scopeId = urlParams.get('scope') || localStorage.getItem('activeScope');

    // 1. استرجاع وتثبيت اسم النطاق وربط زر السجلات
    function setupScopeUI(scopeName) {
        document.getElementById('scopeNameDisplay').innerText = scopeName || "نطاق رئيسي";
        // تحديث رابط زر السجلات ليتضمن كود النطاق
        const licenseBtn = document.getElementById('licenseBtn');
        licenseBtn.href = `/manager/licenses?scope=${scopeId}`;
    }

    // 2. جلب البيانات من السيرفر
    async function loadEmployeeData() {
        if(!scopeId) {
            showToast("كود النطاق مفقود!", true);
            return;
        }
        try {
            const response = await fetch(`/manager/api/get-employees/${scopeId}`);
            const result = await response.json();
            
            if(response.ok) {
                rawData = result.employees;
                setupScopeUI(result.scopeName);
                renderTable(rawData);
                calculateStats(rawData);
            } else {
                showToast("خطأ في الاتصال بالسيرفر", true);
            }
        } catch (err) {
            showToast("حدث خطأ غير متوقع", true);
        }
    }

    // 3. عرض الجدول
    function renderTable(data) {
        const container = document.getElementById('employeeTable');
        if(data.length === 0) {
            container.innerHTML = '<tr><td colspan="7">لا توجد بيانات متاحة</td></tr>';
            return;
        }

        container.innerHTML = data.map(emp => {
            const isExp = new Date(emp.idExpiry) < new Date();
            return `
                <tr>
                    <td>
                        <span class="emp-name">${emp.fullName}</span>
                        <small>${emp.jobTitle || 'موظف'}</small>
                    </td>
                    <td><code>${emp.idNumber}</code></td>
                    <td>${emp.nationality || '---'}</td>
                    <td>${emp.phoneNumber}</td>
                    <td>
                        <b style="color: ${isExp ? 'red' : 'green'}">${formatDate(emp.idExpiry)}</b>
                    </td>
                    <td>
                        <i class="fas fa-shield-alt" style="color: ${emp.hasHealthInsurance ? '#2ed573' : '#ff4757'}"></i>
                    </td>
                    <td>
                        <button class="btn" style="background:var(--info); color:white; padding:8px;" onclick="openProfile('${emp._id}')">
                            <i class="fas fa-eye"></i>
                        </button>
                    </td>
                </tr>
            `;
        }).join('');
    }

    // 4. عرض مصفوفة البيانات (المودال)
    function openProfile(id) {
        const emp = rawData.find(e => e._id === id);
        if(!emp) return;

        const sections = [
            { title: "البيانات الأساسية", icon: "user", class: "box-blue", items: {
                "الاسم": emp.fullName,
                "الجنسية": emp.nationality,
                "رقم الهوية": emp.idNumber,
                "انتهاء الهوية": formatDate(emp.idExpiry)
            }},
            { title: "وثائق السفر", icon: "passport", class: "box-gold", items: {
                "رقم الجواز": emp.passportNumber || 'غير متوفر',
                "انتهاء الجواز": formatDate(emp.passportExpiry),
                "الفرع": emp.branch || 'الرئيسي'
            }},
            { title: "المركبة والتأمين", icon: "car", class: "box-green", items: {
                "لوحة السيارة": emp.carPlate || 'بدون عهدة',
                "رخصة القيادة": emp.hasDrivingLicense ? 'موجودة' : 'لا يوجد',
                "تأمين طبي": emp.hasHealthInsurance ? 'موجود' : 'غير مغطى'
            }}
        ];

        document.getElementById('matrixContent').innerHTML = sections.map(sec => `
            <div class="matrix-box ${sec.class}">
                <div style="font-weight:800; border-bottom:1px solid #ddd; margin-bottom:10px; padding-bottom:5px;">
                    <i class="fas fa-${sec.icon}"></i> ${sec.title}
                </div>
                ${Object.entries(sec.items).map(([label, val]) => `
                    <div class="matrix-row">
                        <span class="matrix-label">${label}</span>
                        <span class="matrix-value">${val || '---'}</span>
                    </div>
                `).join('')}
            </div>
        `).join('');

        document.getElementById('empModal').style.display = 'block';
    }

    // وظائف مساعدة
    function formatDate(d) {
        if(!d) return '---';
        return new Date(d).toLocaleDateString('en-GB');
    }

    function calculateStats(data) {
        document.getElementById('count-total').innerText = data.length;
        document.getElementById('count-cars').innerText = data.filter(e => e.carPlate).length;
        document.getElementById('count-expired').innerText = data.filter(e => new Date(e.idExpiry) < new Date()).length;
        document.getElementById('count-medical').innerText = data.filter(e => e.hasHealthInsurance).length;
    }

    function handleSearch() {
        const term = document.getElementById('mainSearch').value.toLowerCase();
        const filtered = rawData.filter(e => 
            e.fullName.toLowerCase().includes(term) || e.idNumber.includes(term)
        );
        renderTable(filtered);
    }

    function showToast(msg, isError = false) {
        const t = document.getElementById('toast');
        t.innerText = msg;
        t.style.background = isError ? 'var(--danger)' : 'var(--navy)';
        t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 3000);
    }

    function copyRegLink() {
        const link = `${window.location.origin}/employee/register?scope=${scopeId}`;
        navigator.clipboard.writeText(link);
        showToast("تم نسخ الرابط بنجاح");
    }

    function closeModal() { document.getElementById('empModal').style.display = 'none'; }
    function logout() { localStorage.clear(); window.location.href = '/manager/login'; }

    window.onload = loadEmployeeData;
</script>
</body>
</html>